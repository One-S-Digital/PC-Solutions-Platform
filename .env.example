# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pc_solutions"

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=pc-solutions-assets
R2_PUBLIC_URL=https://assets.yourdomain.com
R2_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com

# Redis Cache (Phase 2)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Application URLs
API_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Server Configuration
PORT=3002
NODE_ENV=development

# Logging (Phase 5)
LOG_LEVEL=info  # debug, info, warn, error

# Feature Flags
FEATURE_UPLOAD_CHECKSUMS=true
FEATURE_AUDIT_LOGGING=true
FEATURE_METRICS=true
CACHE_ENABLED=true
DEV_BYPASS_AUTH=false  # NEVER use in production

# SMTP Email (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM="PC Solutions <noreply@yourdomain.com>"

# ClamAV Antivirus (Optional)
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# File Upload Configuration
UPLOAD_MODE=r2  # local or r2
UPLOAD_MAX_MB=50
UPLOAD_ALLOWED_EXT=pdf,png,jpg,jpeg,webp,doc,docx,mp4,mov
UPLOAD_ALLOWED_MIME=application/pdf,image/*,video/*,application/msword

# Session
SESSION_SECRET=your_session_secret_min_32_chars

# API Rate Limiting
RATE_LIMIT_TTL=60000  # 1 minute
RATE_LIMIT_MAX=100    # 100 requests per minute

# Monitoring
PROMETHEUS_ENABLED=true
SENTRY_DSN=  # Optional error tracking

# Development Only
DEV_SEED_DATABASE=false
DEV_ENABLE_PLAYGROUND=true
