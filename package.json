{
  "name": "pc-solutions-platform",
  "private": true,
  "scripts": {
    "prebuild": "pnpm run extract:i18n-keys",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "clean": "turbo run clean",
    "precommit:guard": "node scripts/check-no-raw-imports.mjs",
    "i18n:check": "node scripts/i18n-check.js",
    "translate": "node scripts/translate-i18n-free.js",
    "translate:ai": "node scripts/translate-i18n.js",
    "translate:manual": "node scripts/create-translations-manual.js",
    "translate:simple": "node scripts/translate-simple.js",
    "generate:i18n-types": "ts-node scripts/generate-i18n-types.ts",
    "extract:i18n-keys": "ts-node scripts/extract-i18n-keys.ts",
    "check:i18n-keys": "ts-node scripts/check-i18n-keys.ts",
    "i18n:full-check": "npm run extract:i18n-keys && npm run check:i18n-keys && npm run generate:i18n-types"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "eslint-plugin-i18next": "^6.1.0",
    "glob": "^11.0.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.896.0",
    "@aws-sdk/s3-request-presigner": "^3.896.0",
    "@clerk/backend": "^2.15.0",
    "@clerk/clerk-sdk-node": "^5.0.0",
    "@headlessui/react": "^2.2.8",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.16.2",
    "@sendgrid/mail": "^8.1.6",
    "@tanstack/react-query": "^5.89.0",
    "@types/multer": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.3",
    "@workspace/translations": "workspace:*",
    "axios": "^1.12.2",
    "axios-retry": "^4.5.0",
    "clamdjs": "^1.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.544.0",
    "multer": "^2.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.0.0",
    "reflect-metadata": "^0.2.2",
    "stripe": "^18.5.0",
    "svix": "^1.76.1",
    "tailwindcss": "^4.1.13",
    "translate-google-api": "^1.0.4",
    "vite": "^7.1.7",
    "winston": "^3.17.0"
  }
