{
  "name": "@workspace/translations",
  "version": "1.0.0",
  "description": "Shared translation package for Swiss terminology and common translations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "i18next": "^23.7.6",
    "react-i18next": "^13.5.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0"
  },
  "files": [
    "dist",
    "locales"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./locales/*": "./locales/*",
    "./locales/en/common.json": "./locales/en/common.json",
    "./locales/en/auth.json": "./locales/en/auth.json",
    "./locales/en/dashboard.json": "./locales/en/dashboard.json",
    "./locales/en/pricing.json": "./locales/en/pricing.json",
    "./locales/fr/common.json": "./locales/fr/common.json",
    "./locales/fr/auth.json": "./locales/fr/auth.json",
    "./locales/fr/dashboard.json": "./locales/fr/dashboard.json",
    "./locales/fr/pricing.json": "./locales/fr/pricing.json",
    "./locales/de/common.json": "./locales/de/common.json",
    "./locales/de/auth.json": "./locales/de/auth.json",
    "./locales/de/dashboard.json": "./locales/de/dashboard.json",
    "./locales/de/pricing.json": "./locales/de/pricing.json"
  }
}