{
  "name": "api",
  "version": "0.0.2",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "rimraf dist && node scripts/prebuild-db-setup.mjs",
    "prebuild:render": "node scripts/prebuild-db-setup.mjs",
    "build": "nest build",
    "build:render": "SKIP_SEED=true ./scripts/render-build.sh && SKIP_SEED=true node ./scripts/seed-once.js && pnpm run build",
    "build:render:optimized": "SKIP_SEED=true ./scripts/render-build-optimized.sh && SKIP_SEED=true node ./scripts/seed-once.js && pnpm run build",
    "build:with-migration": "prisma migrate deploy && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit": "jest --testMatch=\"**/*.unit.spec.ts\"",
    "test:integration": "jest --testMatch=\"**/*.integration.spec.ts\" --runInBand",
    "test:auth": "jest --testMatch=\"**/test/auth/**/*.spec.ts\" --runInBand",
    "test:setup": "bash ./scripts/test-setup.sh",
    "start:test": "NODE_ENV=test nest start --watch",
    "db:verify": "ts-node scripts/verify-schema.ts",
    "db:verify:sql": "psql $DATABASE_URL -f scripts/verify-db-schema.sql",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:status": "prisma migrate status",
    "db:pull": "prisma db pull",
    "db:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:init": "./scripts/init-database.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/s3-request-presigner": "^3.888.0",
    "@casl/ability": "^6.7.1",
    "@clerk/backend": "^2.15.0",
    "@clerk/clerk-sdk-node": "^5.0.0",
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.0.1",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.0.1",
    "@prisma/client": "^6.17.1",
    "@sendgrid/mail": "^8.1.5",
    "@types/multer": "^2.0.0",
    "@workspace/types": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cache-manager": "^5.7.6",
    "clamdjs": "^1.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "file-type": "^21.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.1",
    "multer": "^2.0.2",
    "nestjs-pino": "^4.1.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "stripe": "^18.5.0",
    "svix": "^1.4.12",
    "uuid": "^13.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^3.0.6",
    "@types/passport-local": "^1.0.34",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.16.2",
    "rimraf": "^5.0.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}