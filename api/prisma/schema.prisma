  quietHoursEnabled Boolean @default(false)
  quietHoursStart   String? // HH:MM format
  quietHoursEnd     String? // HH:MM format

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation("NotificationPreferences", fields: [userId], references: [id])

  @@map("user_notification_preferences")
}

// Subscription Management System
model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String
  description   String
  price         Float
  currency      String   @default("CHF")
  billingPeriod String   @default("monthly") // monthly, yearly
  features      String[] // Array of feature names
  limits        Json // Usage limits as JSON
  isActive      Boolean  @default(true)
  isPopular     Boolean  @default(false)
  stripePriceId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model PricingTier {
  id            String   @id @default(uuid())
  name          String
  basePrice     Float
  currency      String   @default("CHF")
  billingPeriod String   @default("monthly") // monthly, yearly
  discounts     Json // Discount configuration as JSON
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("pricing_tiers")
}

model DynamicPricingRule {
  id                 String    @id @default(uuid())
  name               String
  conditions         Json // Rule conditions as JSON
  pricingAdjustments Json // Pricing adjustments as JSON
  isActive           Boolean   @default(true)
  validFrom          DateTime  @default(now())
  validUntil         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("dynamic_pricing_rules")
}

model FeatureFlag {
  id                String   @id @default(uuid())
  name              String
  description       String
  key               String   @unique // Unique feature identifier
  isActive          Boolean  @default(true)
  rolloutPercentage Int      @default(0) // 0-100
  targetSegments    String[] // User segments
  conditions        Json // Feature conditions as JSON
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("feature_flags")
}

model BillingTransaction {
  id                    String   @id @default(uuid())
  subscriptionId        String
  amount                Float
  currency              String   @default("CHF")
  status                String   @default("pending") // pending, succeeded, failed, refunded
  stripePaymentIntentId String?
  stripeChargeId        String?
  description           String
  metadata              Json? // Additional transaction data
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("billing_transactions")
}

// System Configuration Management
model SystemSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String
  category    String   @default("general")
  isEncrypted Boolean  @default(false)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model IntegrationConfig {
  id            String    @id @default(uuid())
  name          String
  type          String // auth, payment, email, storage, analytics, other
  provider      String
  isActive      Boolean   @default(true)
  configuration Json // Integration-specific configuration
  credentials   Json // Encrypted credentials
  webhookUrl    String?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("integration_configs")
}

model MaintenanceMode {
  id               String    @id @default(uuid())
  isEnabled        Boolean   @default(false)
  message          String
  allowedPaths     String[] // Paths that remain accessible during maintenance
  allowedRoles     String[] // User roles that remain accessible during maintenance
  estimatedEndTime DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("maintenance_mode")
}

model MaintenanceSchedule {
  id               String   @id @default(uuid())
  name             String
  description      String
  scheduledStart   DateTime
  scheduledEnd     DateTime
  isActive         Boolean  @default(true)
  notificationSent Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("maintenance_schedules")
}

// New Role Management Tables
model AppUser {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String?  @unique
  role      UserRole @default(PARENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets         Asset[]              @relation("AssetUploadedBy")
  roleHistory    AppUserRoleHistory[]
  createdCourses Course[]             @relation("CourseCreator")
}

model AppUserRoleHistory {
  id           BigInt    @id @default(autoincrement())
  userId       String
  previousRole UserRole?
  newRole      UserRole
  changedBy    String // clerkId of actor OR 'system/webhook'
  reason       String?
  changedAt    DateTime  @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Outbox {
  id        BigInt   @id @default(autoincrement())
  topic     String
  payload   Json
  attempts  Int      @default(0)
  nextRunAt DateTime @default(now())
  createdAt DateTime @default(now())
  lastError String?

  @@index([nextRunAt])
}

// Platform Settings and Configuration
model PlatformSettings {
  id                        String   @id @default(uuid())
  platformName              String   @default("ProCrèche Solutions Suisse")
  platformDescription       String?
  platformVersion           String   @default("1.0.0")
  maintenanceMode           Boolean  @default(false)
  maintenanceMessage        String? // Custom message during maintenance
  registrationEnabled       Boolean  @default(true)
  emailVerificationRequired Boolean  @default(true)
  maxFileUploadSize         Int      @default(10485760) // 10MB in bytes
  allowedFileTypes          String[] @default(["jpg", "jpeg", "png", "pdf", "doc", "docx"])
  sessionTimeout            Int      @default(3600) // 1 hour in seconds
  passwordMinLength         Int      @default(8)
  passwordRequireSpecial    Boolean  @default(true)
  twoFactorRequired         Boolean  @default(false)
  apiRateLimit              Int      @default(1000) // requests per hour
  backupFrequency           String   @default("daily") // daily, weekly, monthly
  logRetentionDays          Int      @default(90)
  revision                  Int      @default(1) // For optimistic locking
  updatedBy                 String? // User ID who made last update
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Relations
  updater User? @relation("PlatformSettingsUpdater", fields: [updatedBy], references: [id])

  @@map("platform_settings")
}

// Audit Logging for Compliance and Debugging
model AuditLog {
  id        String   @id @default(uuid())
  entity    String // e.g., "PolicyAlert", "ContentItem", "User"
  entityId  String // ID of the entity that was modified
  action    String // "create", "update", "delete", "upsert"
  actorId   String? // User ID who performed the action
  diff      Json? // Before/after snapshot
  metadata  Json? // Request context (IP, traceId, userAgent, etc.)
  createdAt DateTime @default(now())

  // Relations
  actor User? @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([entity, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

// System Monitoring and Health Checks
model SystemHealthCheck {
  id           String   @id @default(uuid())
  serviceName  String
  status       String // healthy, degraded, down
  responseTime Int? // milliseconds
  lastChecked  DateTime @default(now())
  errorMessage String?
  metadata     Json? // Additional health check data
  createdAt    DateTime @default(now())

  @@map("system_health_checks")
}

model SystemMetrics {
  id          String   @id @default(uuid())
  metricName  String
  metricValue Float
  unit        String? // bytes, seconds, count, etc.
  timestamp   DateTime @default(now())
  metadata    Json? // Additional metric data
  createdAt   DateTime @default(now())

  @@map("system_metrics")
}

model SystemAlert {
  id         String    @id @default(uuid())
  alertType  String // error, warning, info
  title      String
  message    String
  severity   String // low, medium, high, critical
  isResolved Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  metadata   Json? // Additional alert data
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("system_alerts")
}

// Content Management System
model ContentItem {
  id          String   @id @default(uuid())
  title       String
  description String?
  contentType String // document, image, video, audio, other
  fileUrl     String?
  fileSize    Int?
  mimeType    String?
  category    String?
  tags        String[]
  status      String   @default("draft") // draft, published, archived
  isPublic    Boolean  @default(false)
  uploadedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  uploader User @relation("ContentUploader", fields: [uploadedBy], references: [id])

  @@map("content_items")
}

model ContentCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  parent   ContentCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ContentCategory[] @relation("CategoryHierarchy")

  @@map("content_categories")
}

// Policy Alert System
model PolicyAlert {
  id        String    @id @default(uuid())
  title     String
  message   String
  alertType String // info, warning, critical
  regions   String[] // Array of region codes (CH, DE, FR, etc.)
  isActive  Boolean   @default(true)
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  creator User @relation("PolicyAlertCreator", fields: [createdBy], references: [id])

  @@map("policy_alerts")
}

// API Key Management
model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyHash     String    @unique
  permissions String[] // Array of permission strings
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  creator User @relation("ApiKeyCreator", fields: [createdBy], references: [id])

  @@map("api_keys")
}

// Webhook Management
model Webhook {
  id            String    @id @default(uuid())
  name          String
  url           String
  events        String[] // Array of event types
  secret        String? // Webhook secret for verification
  isActive      Boolean   @default(true)
  lastTriggered DateTime?
  failureCount  Int       @default(0)
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  creator User         @relation("WebhookCreator", fields: [createdBy], references: [id])
  logs    WebhookLog[]

  @@map("webhooks")
}

model WebhookLog {
  id           String   @id @default(uuid())
  webhookId    String
  event        String
  payload      Json
  response     Json?
  statusCode   Int?
  success      Boolean
  errorMessage String?
  triggeredAt  DateTime @default(now())

  // Relations
  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_logs")
}

// Foundation Lead Response System
// Tracks individual foundation responses to parent leads
model FoundationLeadResponse {
  id           String   @id @default(uuid())
  leadId       String
  foundationId String   // Organization ID of the foundation
  status       String   // INTERESTED, NOT_INTERESTED, NEEDS_MORE_INFO, ENROLLED
  message      String?  @db.Text
  respondedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  lead         ParentLead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  foundation   Organization @relation("FoundationLeadResponses", fields: [foundationId], references: [id])

  @@unique([leadId, foundationId])
  @@index([foundationId])
  @@index([status])
  @@map("foundation_lead_responses")
}

// Support Ticket System
model SupportTicket {
  id          String    @id @default(uuid())
  userId      String
  subject     String
  message     String    @db.Text
  category    String    @default("GENERAL") // GENERAL, TECHNICAL, BILLING, FEATURE_REQUEST
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user        User             @relation("UserSupportTickets", fields: [userId], references: [id])
  assignee    User?            @relation("AssignedSupportTickets", fields: [assignedTo], references: [id])
  responses   TicketResponse[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@map("support_tickets")
}

model TicketResponse {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  message   String   @db.Text
  isStaff   Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation("UserTicketResponses", fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_responses")
}

// Foundation Calendar Events
model CalendarEvent {
  id                String    @id @default(uuid())
  organizationId    String
  title             String
  description       String?   @db.Text
  eventType         String    // appointment, interview, service, meeting, reminder, custom
  startTime         DateTime
  endTime           DateTime?
  allDay            Boolean   @default(false)
  location          String?
  relatedEntityType String?   // service_request, job_application, parent_lead, etc.
  relatedEntityId   String?
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  organization Organization @relation("OrganizationCalendarEvents", fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User?        @relation("UserCalendarEvents", fields: [createdBy], references: [id])

  @@index([organizationId])
  @@index([startTime])
  @@index([eventType])
  @@map("calendar_events")
}

// Partner Organizations (External Partners/Sponsors)
enum PartnerType {
  ACADEMIC
  CORPORATE
  GOVERNMENTAL
  NON_PROFIT
  MEDIA
  TECHNOLOGY
}

model Partner {
  id            String      @id @default(uuid())
  name          String
  type          PartnerType
  description   String?     @db.Text
  websiteUrl    String?
  countryRegion String?
  contactEmail  String?
  contactPhone  String?
  contactPerson String?
  
  // Asset relations
  logoAssetId   String?
  
  // Status and visibility
  isActive      Boolean     @default(true)
  isFeatured    Boolean     @default(false)
  displayOrder  Int         @default(0)
  
  // Dates
  partnershipStart DateTime?
  partnershipEnd   DateTime?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([isFeatured])
  @@index([displayOrder])
  @@map("partners")
}
