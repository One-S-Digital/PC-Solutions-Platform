  notes       String?
  moderatorId String
  createdAt   DateTime @default(now())

  // Relations
  moderator  User              @relation("ModerationActions", fields: [moderatorId], references: [id])
  moderation ContentModeration @relation(fields: [contentId], references: [contentId])

  @@map("moderation_actions")
}

