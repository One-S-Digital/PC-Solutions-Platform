// ============================================
// INVOICING SYSTEM - Swiss QR-Bill Compliant
// ============================================

// Document Types for invoicing
enum InvoiceDocumentType {
  INVOICE // Standard invoice - payment request
  CREDIT_NOTE // Credit memo - refund/adjustment
  PROFORMA // Proforma invoice - pre-payment request
  QUOTE // Estimate/Quote - non-binding offer
}

// Invoice/Document status (flexible, not strict state machine)
enum InvoiceDocumentStatus {
  DRAFT // Created but not finalized (editable)
  ISSUED // Finalized, number assigned, sent to customer
  SENT // Explicitly marked as sent
  VIEWED // Customer has viewed (client portal)
  PARTIALLY_PAID // Partial payment received
  PAID // Fully paid
  OVERDUE // Past due date, unpaid
  CANCELLED // Voided/cancelled (number preserved)
  VOID // Marked void (number preserved)
  ARCHIVED // Archived for long-term storage
}

// Quote-specific status
enum QuoteStatus {
  DRAFT // Being prepared
  SENT // Sent to client
  VIEWED // Client viewed
  ACCEPTED // Client accepted
  DECLINED // Client declined
  EXPIRED // Past validity date
  CONVERTED // Converted to invoice
}

// Swiss QR-bill reference types
enum InvoiceReferenceType {
  QRR // QR-Reference (27 digits, Mod-10 recursive) - requires QR-IBAN
  SCOR // Structured Creditor Reference (ISO 11649) - standard IBAN
  NON // No reference - manual payment only
}

// Address format for QR-bill
enum InvoiceAddressType {
  STRUCTURED // S - Separate fields (street, building, postal code, city)
  COMBINED // K - Combined address lines (max 2 lines)
}

// Payment terms presets
enum InvoicePaymentTerms {
  DUE_ON_RECEIPT // Payment due immediately
  NET_7 // Due in 7 days
  NET_10 // Due in 10 days
  NET_15 // Due in 15 days
  NET_30 // Due in 30 days (default)
  NET_45 // Due in 45 days
  NET_60 // Due in 60 days
  NET_90 // Due in 90 days
  CUSTOM // Custom due date specified
}

// VAT display mode
enum VatDisplayMode {
  EXCLUDED // VAT added to net amount (default)
  INCLUDED // VAT included in unit price
}

// Invoicing Settings - Per organization configuration
model InvoicingSettings {
  id             String @id @default(uuid())
  organizationId String @unique

  // Company/Issuer Details
  legalName    String? // Official legal name for invoices
  tradingName  String? // Trading/DBA name (optional)
  addressLine1 String? // Street address
  addressLine2 String? // Building/apartment (optional)
  postalCode   String? // Postal/ZIP code
  city         String? // City
  country      String             @default("CH") // ISO country code
  addressType  InvoiceAddressType @default(STRUCTURED)

  // Tax identification
  vatNumber          String? // CHE-123.456.789 MWST format
  registrationNumber String? // Commercial register number (optional)

  // Default bank account reference
  defaultBankAccountId String?

  // QR-bill settings
  qrEnabled            Boolean              @default(true) // Default QR usage
  defaultReferenceType InvoiceReferenceType @default(SCOR)

  // Document defaults
  defaultPaymentTerms   InvoicePaymentTerms @default(NET_30)
  defaultDueDays        Int                 @default(30)
  defaultVatDisplayMode VatDisplayMode      @default(EXCLUDED)
  defaultNotes          String?             @db.Text // Default footer/notes
  defaultLanguage       String              @default("de") // de, fr, it, en

  // Numbering configuration
  invoicePrefix    String  @default("INV")
  creditNotePrefix String  @default("CN")
  proformaPrefix   String  @default("PF")
  quotePrefix      String  @default("QT")
  numberFormat     String  @default("{PREFIX}-{YEAR}-{SEQ:5}") // Template
  yearlyReset      Boolean @default(true) // Reset sequence each year

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization       Organization             @relation("OrganizationInvoicingSettings", fields: [organizationId], references: [id], onDelete: Cascade)
  defaultBankAccount OrganizationBankAccount? @relation("DefaultBankAccount", fields: [defaultBankAccountId], references: [id])

  @@index([organizationId])
  @@map("invoicing_settings")
}

// Organization Bank Accounts - For payment details
model OrganizationBankAccount {
  id             String @id @default(uuid())
  organizationId String

  // Account details
  accountName String // Account holder name
  iban        String // Swiss IBAN (CH/LI, 21 chars)
  bankName    String? // Bank name (optional)
  bic         String? // BIC/SWIFT code (optional)

  // QR-IBAN detection (IID 30000-31999)
  isQrIban Boolean @default(false) // Auto-detected on save

  // Account status
  isDefault  Boolean @default(false) // Default account for org
  isVerified Boolean @default(false) // Verified by admin
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization       Organization        @relation("OrganizationBankAccounts", fields: [organizationId], references: [id], onDelete: Cascade)
  defaultForSettings InvoicingSettings[] @relation("DefaultBankAccount")
  documents          InvoiceDocument[]   @relation("DocumentBankAccount")

  @@unique([organizationId, iban])
  @@index([organizationId])
  @@index([isDefault])
  @@map("organization_bank_accounts")
}

// Document Numbering Sequences - Per issuer + document type
model DocumentSequence {
  id             String              @id @default(uuid())
  organizationId String
  documentType   InvoiceDocumentType
  year           Int // Year for yearly reset
  lastNumber     Int                 @default(0) // Last used sequence number

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation("OrganizationDocumentSequences", fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, documentType, year])
  @@index([organizationId])
  @@map("document_sequences")
}

// Main Invoice Document Model
model InvoiceDocument {
  id String @id @default(uuid())

  // Document identification
  documentType    InvoiceDocumentType
  documentNumber  String? // Assigned on issuance, immutable after
  referenceNumber String? // QRR/SCOR reference for payment
  referenceType   InvoiceReferenceType @default(SCOR)

  // Status
  status      InvoiceDocumentStatus @default(DRAFT)
  quoteStatus QuoteStatus? // Only for QUOTE type

  // Parties
  issuerOrgId        String // Creditor organization
  recipientOrgId     String // Debtor organization
  recipientContactId String? // Optional: specific contact person
  createdById        String // User who created
  issuedById         String? // User who issued (finalized)

  // Snapshot of issuer details at issuance (immutable)
  issuerSnapshot    Json? // { name, address, vatNumber, etc. }
  recipientSnapshot Json? // { name, address, vatNumber, etc. }

  // Bank account used
  bankAccountId String?

  // QR-bill settings for this document
  qrEnabled     Boolean @default(true)
  qrPayloadHash String? // SHA-256 hash of QR payload (when generated)

  // ============================================
  // AMOUNTS - All in minor units (centimes) as BigInt
  // ============================================
  subtotalMinor           BigInt @default(0) // Sum of line items before tax
  discountMinor           BigInt @default(0) // Invoice-level discount amount
  netMinor                BigInt @default(0) // subtotalMinor - discountMinor
  vatMinor                BigInt @default(0) // Total VAT amount
  totalMinor              BigInt @default(0) // netMinor + vatMinor
  roundingAdjustmentMinor BigInt @default(0) // Rounding difference for audit

  // Payment tracking
  paidMinor    BigInt @default(0) // Amount paid so far
  balanceMinor BigInt @default(0) // totalMinor - paidMinor

  // VAT display mode for this document
  vatDisplayMode VatDisplayMode @default(EXCLUDED)

  // Currency (CHF only for v1)
  currency String @default("CHF")

  // Dates
  documentDate       DateTime            @default(now()) // Invoice/quote date
  dueDate            DateTime? // Payment due date
  paymentTerms       InvoicePaymentTerms @default(NET_30)
  validUntil         DateTime? // For quotes: validity expiry
  servicePeriodStart DateTime? // Service period start
  servicePeriodEnd   DateTime? // Service period end

  // Notes and references
  notes         String? @db.Text // Public notes on document
  internalNotes String? @db.Text // Internal notes (not on PDF)
  poNumber      String? // Customer's purchase order number

  // Credit note linking
  originalDocumentId String? // For credit notes: reference to original invoice

  // PDF versioning
  currentPdfVersion Int @default(0) // 0 = no PDF yet, 1+ = version number

  // Language for PDF generation
  language String @default("de")

  // Timestamps
  issuedAt    DateTime? // When document was issued/finalized
  sentAt      DateTime? // When document was sent
  paidAt      DateTime? // When fully paid
  cancelledAt DateTime? // When cancelled/voided
  archivedAt  DateTime? // When archived

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  issuerOrg        Organization             @relation("IssuedDocuments", fields: [issuerOrgId], references: [id])
  recipientOrg     Organization             @relation("ReceivedDocuments", fields: [recipientOrgId], references: [id])
  recipientContact User?                    @relation("DocumentRecipientContact", fields: [recipientContactId], references: [id])
  createdBy        User                     @relation("CreatedDocuments", fields: [createdById], references: [id])
  issuedBy         User?                    @relation("IssuedDocuments", fields: [issuedById], references: [id])
  bankAccount      OrganizationBankAccount? @relation("DocumentBankAccount", fields: [bankAccountId], references: [id])
  originalDocument InvoiceDocument?         @relation("CreditNoteReference", fields: [originalDocumentId], references: [id])
  creditNotes      InvoiceDocument[]        @relation("CreditNoteReference")

  lineItems   InvoiceLineItem[]
  payments    InvoicePayment[]
  pdfVersions InvoicePdfVersion[]
  auditLogs   InvoiceAuditLog[]

  @@unique([issuerOrgId, documentNumber])
  @@index([issuerOrgId])
  @@index([recipientOrgId])
  @@index([status])
  @@index([documentType])
  @@index([documentDate])
  @@index([dueDate])
  @@index([createdById])
  @@map("invoice_documents")
}

// Invoice Line Items
model InvoiceLineItem {
  id         String @id @default(uuid())
  documentId String

  // Position/ordering
  position Int @default(0)

  // Item details
  description String // Line item description
  details     String? @db.Text // Additional details
  quantity    Decimal @db.Decimal(12, 4) // Quantity (supports decimals)
  unitLabel   String? // e.g., "hours", "pieces", "kg"

  // ============================================
  // PRICING - All in minor units (centimes) as BigInt
  // ============================================
  unitPriceMinor BigInt // Price per unit in centimes

  // Line-level discount (optional)
  discountPercent Decimal? @db.Decimal(5, 2) // e.g., 10.00 = 10%
  discountMinor   BigInt   @default(0) // Calculated discount amount

  // Line totals (calculated)
  lineSubtotalMinor BigInt @default(0) // quantity * unitPriceMinor
  lineNetMinor      BigInt @default(0) // lineSubtotalMinor - discountMinor

  // ============================================
  // VAT - Stored in basis points
  // ============================================
  vatRateBps Int    @default(0) // VAT rate in basis points (810 = 8.1%)
  vatMinor   BigInt @default(0) // Calculated VAT amount

  // Line total including VAT
  lineTotalMinor BigInt @default(0) // lineNetMinor + vatMinor (or lineNetMinor if VAT included)

  // Reference to original line (for credit notes)
  originalLineId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  document        InvoiceDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  originalLine    InvoiceLineItem?  @relation("CreditNoteLine", fields: [originalLineId], references: [id])
  creditNoteLines InvoiceLineItem[] @relation("CreditNoteLine")

  @@index([documentId])
  @@index([position])
  @@map("invoice_line_items")
}

// Invoice Payments
model InvoicePayment {
  id         String @id @default(uuid())
  documentId String

  // Payment amount in minor units (centimes)
  amountMinor BigInt

  // Payment details
  paymentDate    DateTime @default(now())
  paymentMethod  String? // bank_transfer, stripe, cash, etc.
  transactionRef String? // Bank reference or Stripe payment intent

  // Notes
  notes String? @db.Text

  // Stripe integration (optional)
  stripePaymentIntentId String?

  // Refund tracking
  isRefund          Boolean @default(false)
  refundedPaymentId String? // Reference to original payment if this is a refund

  // Audit
  recordedById String // User who recorded this payment

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  document        InvoiceDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recordedBy      User             @relation("RecordedPayments", fields: [recordedById], references: [id])
  refundedPayment InvoicePayment?  @relation("PaymentRefund", fields: [refundedPaymentId], references: [id])
  refunds         InvoicePayment[] @relation("PaymentRefund")

  @@index([documentId])
  @@index([paymentDate])
  @@index([recordedById])
  @@map("invoice_payments")
}

// Invoice PDF Versions
model InvoicePdfVersion {
  id         String @id @default(uuid())
  documentId String

  // Version number
  version Int @default(1)

  // Asset reference
  assetId String // Reference to Asset for PDF storage

  // QR payload hash at time of generation
  qrPayloadHash String?

  // Generation metadata
  generatedById String // User who triggered generation
  generatedAt   DateTime @default(now())

  // Reason for regeneration (if version > 1)
  regenerationReason String?

  // Relations
  document    InvoiceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  generatedBy User            @relation("GeneratedPdfVersions", fields: [generatedById], references: [id])

  @@unique([documentId, version])
  @@index([documentId])
  @@map("invoice_pdf_versions")
}

// Invoice Audit Log - Immutable, append-only
model InvoiceAuditLog {
  id         String @id @default(uuid())
  documentId String

  // Action type
  action String // created, updated, issued, sent, paid, cancelled, etc.

  // Change details
  field    String? // Field that changed (null for non-field actions)
  oldValue String? @db.Text // Previous value (JSON stringified)
  newValue String? @db.Text // New value (JSON stringified)

  // Full snapshot (optional, for major changes)
  snapshot Json? // Full document state at this point

  // Actor
  actorId String // User who made the change
  actorIp String? // IP address (for compliance)

  // Timestamp (immutable)
  createdAt DateTime @default(now())

  // Relations
  document InvoiceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actor    User            @relation("InvoiceAuditActor", fields: [actorId], references: [id])

  @@index([documentId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("invoice_audit_logs")
}

// Invoicing Settings Audit Log - For settings changes
model InvoicingSettingsAuditLog {
  id             String @id @default(uuid())
  organizationId String

  // Action type
  action String // created, updated

  // Change details
  field    String? // Field that changed
  oldValue String? @db.Text // Previous value
  newValue String? @db.Text // New value

  // Actor
  actorId String
  actorIp String?

  createdAt DateTime @default(now())

  // Relations
  organization Organization @relation("InvoicingSettingsAuditLogs", fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User         @relation("InvoicingSettingsAuditActor", fields: [actorId], references: [id])

  @@index([organizationId])
  @@index([actorId])
  @@index([createdAt])
  @@map("invoicing_settings_audit_logs")
}
