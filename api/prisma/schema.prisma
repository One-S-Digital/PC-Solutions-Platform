  // Relations
  lesson    CourseLesson   @relation(fields: [lessonId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("course_quizzes")
}

model QuizQuestion {
  id           String   @id @default(uuid())
  quizId       String
  questionText String
  questionType QuizType
