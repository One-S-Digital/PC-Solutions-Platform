// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  SUPER_ADMIN
  ADMIN
  FOUNDATION
  PRODUCT_SUPPLIER
  SERVICE_PROVIDER
  EDUCATOR
  PARENT
}

enum OrganizationType {
  FOUNDATION
  PRODUCT_SUPPLIER
  SERVICE_PROVIDER
}

enum AssetKind {
  AVATAR
  LOGO
  COVER_IMAGE
  PRODUCT_IMAGE
  DOCUMENT
  CV
  CATALOG_PDF
  CATALOG_CSV
  FRONTEND_LOGO
  FRONTEND_FAVICON
  FRONTEND_OG_IMAGE
  ADMIN_LOGO
  ADMIN_FAVICON
  SIDEBAR_LOGO
  ELEARNING
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  PAST_DUE
}

enum SubscriptionTier {
  BASIC
  ESSENTIAL
  PROFESSIONAL
  ENTERPRISE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  FILLED
}

enum JobContractType {
  FULL_TIME
  PART_TIME
  CDI
  CDD
  INTERNSHIP
}

enum ServiceCategory {
  CLEANING
  IT_SUPPORT
  MAINTENANCE
  CONSULTING
  TRAINING
  OTHER
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContentType {
  VIDEO
  DOCUMENT
  QUIZ
  TEXT
  IMAGE
}

enum LessonStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum QuizType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  ESSAY
  MATCHING
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum ConversationType {
  DIRECT
  GROUP
  SUPPORT
}

enum TranslationStatus {
  PENDING
  MT_DONE
  REVIEWED
  APPROVED
}

// Core Models
model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String?  @unique
  firstName String?
  lastName  String?
  role      UserRole

  // Additional fields for educators from onboarding guide
  phoneNumber    String?
  workExperience String? // JSON string or text field
  education      String? // JSON string or text field
  certifications String[] // Array of certifications
  skills         String[] // Array of skills
  availability   String? // Availability information
  cvUrl          String? // URL to CV document
  shortBio       String? // Short bio/description for profile

  // Avatar asset relation
  avatarAssetId String?
  avatarAsset   Asset?  @relation("UserAvatar", fields: [avatarAssetId], references: [id])

  // Stripe integration
  stripeCustomerId String? @unique

  // Activity tracking
  lastActiveAt DateTime?
  isActive     Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organizations     UserOrganization[]
  applications      JobApplication[]
  subscriptions     UserSubscription[]
  mainSubscriptions Subscription[] // Main subscription model
  licenses          License[]

  // E-Learning relations
  courseEnrollments CourseEnrollment[]
  certificates      Certificate[]
  courseDiscussions CourseDiscussion[]
  discussionReplies DiscussionReply[]

  // Enhanced messaging relations
  conversations    ConversationParticipant[]
  sentMessages     Message[]                 @relation("MessageSender")
  receivedMessages Message[]                 @relation("MessageReceiver")

  // User activity tracking
  activities UserActivity[] @relation("UserActivity")

  // Content moderation relations
  reportedContent   ContentModeration[] @relation("ContentReporter")
  moderatedContent  ContentModeration[] @relation("ContentModerator")
  moderationActions ModerationAction[]  @relation("ModerationActions")

  // Email notification relations
  emailLogs               EmailLog[]                   @relation("EmailLogs")
  notificationPreferences UserNotificationPreferences? @relation("NotificationPreferences")

  // New admin features relations
  contentItems            ContentItem[]      @relation("ContentUploader")
  policyAlerts            PolicyAlert[]      @relation("PolicyAlertCreator")
  auditLogs               AuditLog[]         @relation("AuditLogActor")
  platformSettingsUpdates PlatformSettings[] @relation("PlatformSettingsUpdater")
  apiKeys                 ApiKey[]           @relation("ApiKeyCreator")
  webhooks                Webhook[]          @relation("WebhookCreator")

  // Support ticket relations
  supportTickets         SupportTicket[]  @relation("UserSupportTickets")
  assignedTickets        SupportTicket[]  @relation("AssignedSupportTickets")
  ticketResponses        TicketResponse[] @relation("UserTicketResponses")

  // Calendar event relations
  calendarEvents         CalendarEvent[]  @relation("UserCalendarEvents")

  @@map("users")
}

model Organization {
  id          String           @id @default(uuid())
  name        String
  type        OrganizationType
  region      String?
  description String?
  vatNumber   String?

  // Additional fields from onboarding guide
  contactPerson        String?
  phoneNumber          String?
  canton               String? // Legacy single canton field
  regionsServed        String[] // Multiple cantons/regions served
  languages            String[] // Languages spoken/offered
  capacity             Int? // For foundations - number of children
  pedagogy             String[] // Educational approaches for foundations
  productCategory      String? // For suppliers - legacy single category
  productCategories    String[] @default([]) // For suppliers - new flexible category tags
  serviceType          String? // For service providers
  minimumOrderQuantity Int? // For suppliers
  directOrderLink      String? // For suppliers
  catalogUrl           String? // For suppliers
  serviceCategories    String[] // For service providers
  deliveryType         String? // On-site, Remote, Hybrid for service providers
  bookingLink          String? // For service providers

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  // Asset relations
  logoAssetId  String?
  logoAsset    Asset?  @relation("OrganizationLogo", fields: [logoAssetId], references: [id])
  coverAssetId String?
  coverAsset   Asset?  @relation("OrganizationCover", fields: [coverAssetId], references: [id])

  // Relations
  members          UserOrganization[]
  products         Product[]
  catalogs         Catalog[]
  serviceProviders ServiceProvider[]
  jobListings      JobListing[]
  subscriptions    Subscription[]
  orders           Order[]
  serviceRequests  ServiceRequest[]

  // Foundation-specific relations
  leadResponses    FoundationLeadResponse[] @relation("FoundationLeadResponses")
  calendarEvents   CalendarEvent[]          @relation("OrganizationCalendarEvents")

  @@map("organizations")
}

model UserOrganization {
  userId         String
  organizationId String
  role           UserRole
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@map("user_organizations")
}

model Asset {
  id           String    @id @default(uuid())
  kind         AssetKind
  filename     String
  publicUrl    String
  storageKey   String
  mimeType     String?
  size         Int?
  uploadedById String
  etag         String? // ETag from R2/S3 for verification
  checksum     String? // SHA-256 checksum (base64) for integrity
  version      Int       @default(1) // Version for response/schema changes

  // Content categorization fields
  category       String? // HR_DOCUMENT, ELEARNING, STATE_POLICY, etc. (content type)
  contentCategory String? // Child Development, Onboarding, Education Policy, etc. (actual category)
  title       String?
  description String?
  metadata    Json? // Legacy/flexible metadata (deprecated, use typed fields below)

  // Typed content fields (replaces JSON metadata)
  contentType    String? // COURSE, VIDEO, PDF, LINK (for e-learning)
  language       String? // EN, FR, DE
  accessRoles    String[] @default([]) // Array of UserRole values
  status         String?  @default("Draft") // Draft, Published, Archived, etc.
  contentPreview String? // Short preview/description for listing
  tags           String[] @default([]) // Searchable tags

  // E-Learning specific fields
  duration        String? // e.g., "2 hours, 30 minutes"
  lessons         Int? // Number of lessons (for COURSE type)
  videoSourceType String? // 'upload' or 'url' (for VIDEO type)

  // HR Document specific fields
  fileType      String? // PDF, DOCX, XLSX, etc.
  versionNumber String? // Document version
  effectiveDate DateTime? // When document becomes effective
  reviewDate    DateTime? // Next review date

  // State Policy specific fields
  country        String? // Switzerland, Germany, Austria, France
  region         String? // Canton/State/Region
  policyType     String? // Regulation, Guideline, Standard, Directive, Law
  isCritical     Boolean   @default(false) // Critical policy flag
  expirationDate DateTime? // Policy expiration date
  externalLink   String? // Link to official policy document

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - after migration, points to AppUser
  uploader AppUser @relation("AssetUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  // Organization asset relations
  organizationLogos  Organization[] @relation("OrganizationLogo")
  organizationCovers Organization[] @relation("OrganizationCover")

  // User asset relations
  userAvatars User[] @relation("UserAvatar")

  // Product relations
  products Product[]

  // Catalog relations
  catalogPdfs Catalog[] @relation("CatalogPdf")
  catalogCsvs Catalog[] @relation("CatalogCsv")

  // Frontend customization relations
  frontendLogos    FrontendSettings[] @relation("FrontendLogo")
  frontendFavicons FrontendSettings[] @relation("FrontendFavicon")
  frontendOgImages FrontendSettings[] @relation("FrontendOgImage")
  adminLogos       FrontendSettings[] @relation("AdminLogo")
  adminFavicons    FrontendSettings[] @relation("AdminFavicon")
  sidebarLogos     FrontendSettings[] @relation("SidebarLogo")

  @@index([storageKey])
  @@index([etag])
  @@index([category])
  @@index([contentCategory])
  @@index([contentType])
  @@index([language])
  @@index([status])
  @@index([country])
  @@index([region])
  @@index([isCritical])
  @@map("assets")
}

model Product {
  id                 String                     @id @default(uuid())
  title              String
  subtitle           String?
  description        String?
  price              Float?
  priceCurrency      String?                    @default("CHF")
  category           String? // Keep for backward compatibility
  primaryCategory    String?
  categories         String[]                   @default([]) // Flexible categories as tags
  tags               String[]                   @default([])
  productHighlights  String[]                   @default([])
  unitOfMeasure      String?
  status             String                     @default("ACTIVE") // ACTIVE, INACTIVE, PENDING, REJECTED
  availabilityStatus ProductAvailabilityStatus  @default(ACTIVE)
  isActive           Boolean                    @default(true)
  sku                String?
  vendorSku          String?
  ean                String?
  minOrderQuantity   Int?
  maxOrderQuantity   Int?
  stockStatus        String?
  deliveryLeadTimeDays Int?
  restockCadence     String?
  usageNotes         String?
  packagingDetails   String?
  materials          String?
  complianceTags     String[]                   @default([])
  allergens          String[]                   @default([])
  ageRanges          String[]                   @default([])
  deliveryMethods    String[]                   @default([])
  deliveryFees       Json?
  supportedCantons   String[]                   @default([])
  visibilityStart    DateTime?
  visibilityEnd      DateTime?
  volumePricing      Json?
  variants           Json?
  supplierId         String
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  // Asset references
  imageAssetId     String?
  galleryAssetIds  String[] @default([])
  specSheetAssetId String?
  msdsAssetId      String?

  imageAsset Asset? @relation(fields: [imageAssetId], references: [id])

  // Relations
  supplier Organization @relation(fields: [supplierId], references: [id])
  orders   OrderItem[]

  @@map("products")
}

enum ProductAvailabilityStatus {
  ACTIVE
  INACTIVE
  DRAFT
  OUT_OF_STOCK
}

model Catalog {
  id          String   @id @default(uuid())
  title       String
  description String?
  supplierId  String
  pdfAssetId  String?
  csvAssetId  String?
  isActive    Boolean  @default(true)
  uploadedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Asset relations
  pdfAsset Asset? @relation("CatalogPdf", fields: [pdfAssetId], references: [id])
  csvAsset Asset? @relation("CatalogCsv", fields: [csvAssetId], references: [id])

  // Relations
  supplier Organization @relation(fields: [supplierId], references: [id])

  @@map("catalogs")
}

model Service {
  id           String          @id @default(uuid())
  title        String
  description  String?
  category     ServiceCategory // Keep for backward compatibility
  categories   String[]        @default([]) // New flexible categories as tags
  price        Float?
  priceInfo    String?
  availability String?
  deliveryType String?         @default("On-site")
  tags         String[]        @default([])
  imageUrl     String?
  isActive     Boolean         @default(true)
  providerId   String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  provider ServiceProvider  @relation(fields: [providerId], references: [id])
  requests ServiceRequest[]

  @@map("services")
}

model ServiceProvider {
  id             String   @id @default(uuid())
  organizationId String   @unique
  deliveryType   String? // "On-site", "Remote", "Hybrid"
  bookingLink    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  services     Service[]

  @@map("service_providers")
}

model JobListing {
  id               String          @id @default(uuid())
  title            String
  description      String?
  requirements     String[]        @default([])
  benefits         String[]        @default([])
  responsibilities String[]        @default([])
  qualifications   String[]        @default([])
  location         String?
  salary           String?
  salaryRange      String?
  contractType     JobContractType @default(FULL_TIME)
  startDate        DateTime?
  status           JobStatus       @default(DRAFT)
  foundationId     String
  publishedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  foundation   Organization     @relation(fields: [foundationId], references: [id])
  applications JobApplication[]

  @@map("job_listings")
}

model JobApplication {
  id           String            @id @default(uuid())
  jobListingId String
  candidateId  String
  coverLetter  String?
  cvUrl        String?
  cvAssetId    String?
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relations
  jobListing JobListing @relation(fields: [jobListingId], references: [id])
  candidate  User       @relation(fields: [candidateId], references: [id])

  @@unique([jobListingId, candidateId])
  @@map("job_applications")
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String? // Optional user ID for user-based subscriptions
  organizationId       String? // Optional organization ID for org-based subscriptions
  planId               String
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String? // Stripe customer ID
  tier                 SubscriptionTier
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Relations
  user         User?                @relation(fields: [userId], references: [id])
  organization Organization?        @relation(fields: [organizationId], references: [id])
  plan         SubscriptionPlan     @relation(fields: [planId], references: [id])
  transactions BillingTransaction[]

  @@map("subscriptions")
}

model Order {
  id             String   @id @default(uuid())
  organizationId String
  totalAmount    Float
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  items        OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  // Relations
  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model ServiceRequest {
  id             String    @id @default(uuid())
  organizationId String
  serviceId      String
  description    String?
  status         String    @default("PENDING")
  requestedAt    DateTime  @default(now())
  scheduledAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])

  @@map("service_requests")
}

model ParentLead {
  id           String  @id @default(uuid())
  parentName   String
  parentEmail  String
  parentPhone  String?
  childName    String
  childAge     Int
  message      String?
  foundationId String?

  // Additional fields from onboarding guide
  preferredLocation   String? // Preferred canton/location
  preferredLanguages  String[] // Preferred languages
  specialRequirements String? // Special needs or requirements

  // Additional fields for lead management
  source String? // Source of the lead (website, referral, etc.)

  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  foundationResponses FoundationLeadResponse[]

  @@index([status])
  @@index([foundationId])
  @@map("parent_leads")
}

// Translation tables for i18n

// Static UI translations (buttons, labels, messages)
model StaticTranslation {
  namespace   String
  key         String
  lang        String
  value       String    @db.Text
  updatedAt   DateTime  @updatedAt
  updatedBy   String?
  createdAt   DateTime  @default(now())
  needsReview Boolean   @default(false)
  reviewedBy  String?
  reviewedAt  DateTime?

  @@id([namespace, key, lang])
  @@index([namespace, lang])
  @@index([key])
  @@map("static_translations")
}

// Enhanced Entity Translation with lifecycle states
model EntityTranslation {
  entityType   String
  entityId     String
  lang         String
  field        String
  text         String            @db.Text
  origin       String            @default("machine")
  status       TranslationStatus @default(PENDING)
  verified     Boolean           @default(false)
  sourceHash   String
  updatedAt    DateTime          @updatedAt
  translatedAt DateTime?
  mtProvider   String?
  approvedAt   DateTime?
  approvedBy   String?
  reviewedAt   DateTime?
  reviewedBy   String?

  @@id([entityType, entityId, lang, field])
  @@index([entityType, lang])
  @@index([status, updatedAt])
  @@map("entity_translations")
}

model EntitySource {
  entityType String
  entityId   String
  sourceLang String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([entityType, entityId])
  @@map("entity_sources")
}

// Translation Memory: Cache MT results to avoid re-translating
model TranslationMemory {
  id             String   @id @default(cuid())
  sourceTextHash String
  sourceLang     String
  targetLang     String
  translatedText String   @db.Text
  mtProvider     String
  usageCount     Int      @default(1)
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime @updatedAt

  @@unique([sourceTextHash, sourceLang, targetLang])
  @@index([sourceLang, targetLang])
  @@map("translation_memory")
}

// Track translation releases for cache-busting
model TranslationRelease {
  id          String   @id @default(cuid())
  version     String   @unique
  description String?
  createdBy   String?
  createdAt   DateTime @default(now())
  isActive    Boolean  @default(false)

  @@index([isActive, createdAt])
  @@map("translation_releases")
}

// Audit log for translation changes
model TranslationAuditLog {
  id         String   @id @default(cuid())
  type       String // 'static' | 'dynamic'
  namespace  String?
  entityType String?
  entityId   String?
  key        String?
  field      String?
  lang       String
  action     String // 'create' | 'update' | 'delete' | 'approve' | 'review'
  oldValue   String?  @db.Text
  newValue   String?  @db.Text
  userId     String
  createdAt  DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@map("translation_audit_logs")
}

// Track MT API usage and costs
model MTCostTracking {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  provider   String
  sourceLang String
  targetLang String
  characters Int
  cost       Decimal  @db.Decimal(10, 4)
  jobCount   Int      @default(0)

  @@unique([date, provider, sourceLang, targetLang])
  @@index([date, provider])
  @@map("mt_cost_tracking")
}

// Subscription System Models
model Plan {
  id          String   @id @default(uuid())
  code        String   @unique // BASIC, ESSENTIAL, PROFESSIONAL, ENTERPRISE
  name        String
  description String?
  features    String[] // Array of feature codes
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  subscriptions UserSubscription[]
  licenses      License[]
  planPrices    PlanPrice[]

  @@map("plans")
}

model PlanPrice {
  id            String   @id @default(uuid())
  planId        String
  cadence       String // monthly, annual
  kind          String // recurring, one_time
  stripePriceId String   @unique
  amount        Int // Amount in cents (CHF)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  plan Plan @relation(fields: [planId], references: [id])

  @@map("plan_prices")
}

model UserSubscription {
  id                   String    @id @default(uuid())
  userId               String
  planId               String
  cadence              String // monthly, annual
  stripeSubscriptionId String    @unique
  status               String // active, trialing, past_due, canceled, incomplete
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  trialStart           DateTime?
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  canceledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@map("user_subscriptions")
}

model License {
  id                    String   @id @default(uuid())
  userId                String
  planId                String
  stripePaymentIntentId String   @unique
  status                String // active, revoked, expired
  accessExpiresAt       DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@map("licenses")
}

// E-Learning Platform Models
model CourseCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  // Relations
  parent   CourseCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children CourseCategory[] @relation("CategoryHierarchy")
  courses  Course[]

  @@map("course_categories")
}

model Course {
  id                String       @id @default(uuid())
  title             String
  description       String?
  shortDescription  String?
  categoryId        String?
  difficultyLevel   String // beginner, intermediate, advanced
  estimatedDuration Int // minutes
  thumbnailUrl      String?
  status            CourseStatus @default(DRAFT)
  createdBy         String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Relations
  category     CourseCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  creator      AppUser            @relation("CourseCreator", fields: [createdBy], references: [id])
  modules      CourseModule[]
  enrollments  CourseEnrollment[]
  discussions  CourseDiscussion[]
  certificates Certificate[]

  @@map("courses")
}

model CourseModule {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?
  sortOrder   Int      @default(0)
  isRequired  Boolean  @default(true)
  createdAt   DateTime @default(now())

  // Relations
  course  Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons CourseLesson[]

  @@map("course_modules")
}

model CourseLesson {
  id          String      @id @default(uuid())
  moduleId    String
  title       String
  contentType ContentType
  contentUrl  String?
  contentText String?
  duration    Int? // minutes
  sortOrder   Int         @default(0)
  isRequired  Boolean     @default(true)
  createdAt   DateTime    @default(now())

  // Relations
  module   CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
  quizzes  CourseQuiz[]

  @@map("course_lessons")
}

model CourseEnrollment {
  id                 String    @id @default(uuid())
  userId             String
  courseId           String
  enrolledAt         DateTime  @default(now())
  completedAt        DateTime?
  progressPercentage Decimal   @default(0) @db.Decimal(5, 2)
  lastAccessedAt     DateTime  @default(now())

  // Relations
  user         User             @relation(fields: [userId], references: [id])
  course       Course           @relation(fields: [courseId], references: [id])
  progress     LessonProgress[]
  quizAttempts QuizAttempt[]

  @@unique([userId, courseId])
  @@map("course_enrollments")
}

model LessonProgress {
  id           String       @id @default(uuid())
  enrollmentId String
  lessonId     String
  completedAt  DateTime?
  timeSpent    Int          @default(0) // seconds
  status       LessonStatus @default(NOT_STARTED)

  // Relations
  enrollment CourseEnrollment @relation(fields: [enrollmentId], references: [id])
  lesson     CourseLesson     @relation(fields: [lessonId], references: [id])

  @@unique([enrollmentId, lessonId])
  @@map("lesson_progress")
}

model CourseQuiz {
  id              String   @id @default(uuid())
  lessonId        String
  title           String
  instructions    String?
  passingScore    Int      @default(70)
  timeLimit       Int? // minutes
  attemptsAllowed Int      @default(3)
  createdAt       DateTime @default(now())

