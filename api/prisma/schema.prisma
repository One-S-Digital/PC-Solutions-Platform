// User Activity Tracking
model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  action    String // e.g., "LOGIN", "PROFILE_UPDATE", "PASSWORD_CHANGE"
  details   Json? // Additional context about the action
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation("UserActivity", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activities")
}

// Content Moderation System
model ContentModeration {
  id          String  @id @default(uuid())
  contentId   String // ID of the content being moderated
  contentType String // PRODUCT, JOB_LISTING, SERVICE, ORGANIZATION, USER_PROFILE
  status      String  @default("PENDING") // PENDING, APPROVED, REJECTED, FLAGGED
  priority    String  @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  reason      String? // Reason for moderation/flagging
  notes       String? // Additional notes from moderator

  // User tracking
  reporterId  String? // User who reported/flagged the content
  moderatorId String? // Admin who moderated the content

  // Timestamps
  createdAt   DateTime  @default(now())
  flaggedAt   DateTime?
  moderatedAt DateTime?

  // Relations
  reporter  User?              @relation("ContentReporter", fields: [reporterId], references: [id])
  moderator User?              @relation("ContentModerator", fields: [moderatorId], references: [id])
  actions   ModerationAction[]

  @@unique([contentId])
  @@map("content_moderation")
}

model ModerationAction {
  id          String   @id @default(uuid())
  contentId   String
  contentType String
  action      String // APPROVE, REJECT, FLAG, REQUEST_CHANGES
  reason      String?
  notes       String?
  moderatorId String
  createdAt   DateTime @default(now())

  // Relations
  moderator  User              @relation("ModerationActions", fields: [moderatorId], references: [id])
  moderation ContentModeration @relation(fields: [contentId], references: [contentId])

  @@map("moderation_actions")
}

// Email Notification System
model EmailTemplate {
  id          String   @id @default(uuid())
  name        String
  event       String   @unique // Event identifier (e.g., 'account_verification')
  subject     String
  htmlContent String
  textContent String
  variables   String[] // Template variables
  category    String // Category for grouping templates
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("email_templates")
}

model EmailLog {
  id         String   @id @default(uuid())
  userId     String?
  event      String
  recipient  String
  templateId String?
  messageId  String? // SendGrid message ID
  status     String // sent, delivered, opened, clicked, bounced, failed
  payload    Json? // Template variables used
  error      String? // Error message if failed
  createdAt  DateTime @default(now())

  // Relations
  user User? @relation("EmailLogs", fields: [userId], references: [id])

  @@map("email_logs")
}

model ScheduledEmail {
  id          String   @id @default(uuid())
  event       String
  recipient   String
  payload     Json
  scheduledAt DateTime
  status      String   @default("pending") // pending, sent, failed
  createdAt   DateTime @default(now())

  @@map("scheduled_emails")
}

model UserNotificationPreferences {
  id                 String  @id @default(uuid())
  userId             String  @unique
  emailNotifications Boolean @default(true)

  // Category preferences
  authentication    Boolean @default(true)
  userManagement    Boolean @default(true)
  jobRecruitment    Boolean @default(true)
  messaging         Boolean @default(true)
  marketplace       Boolean @default(true)
  leadManagement    Boolean @default(true)
  subscription      Boolean @default(true)
  contentModeration Boolean @default(true)
  systemAdmin       Boolean @default(true)
  marketing         Boolean @default(true)

