}

model QuizAnswer {
  id         String   @id @default(uuid())
  questionId String
  answerText String
  isCorrect  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  // Relations
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

model QuizAttempt {
  id            String   @id @default(uuid())
