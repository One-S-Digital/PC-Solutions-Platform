// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  SUPER_ADMIN
  ADMIN
  FOUNDATION
  PRODUCT_SUPPLIER
  SERVICE_PROVIDER
  EDUCATOR
  PARENT
}

enum OrganizationType {
  FOUNDATION
  PRODUCT_SUPPLIER
  SERVICE_PROVIDER
}

enum AssetKind {
  AVATAR
  LOGO
  COVER_IMAGE
  PRODUCT_IMAGE
  DOCUMENT
  CV
  CATALOG_PDF
  CATALOG_CSV
  FRONTEND_LOGO
  FRONTEND_FAVICON
  FRONTEND_OG_IMAGE
  ADMIN_LOGO
  ADMIN_FAVICON
  SIDEBAR_LOGO
  ELEARNING
  COMPANY_PROFILE_DOC
}

enum SubscriptionStatus {
  ACTIVE        // Subscription is active and valid
  INACTIVE      // Subscription is inactive (not started or expired)
  PAUSED        // Subscription is temporarily paused
  CANCELLED     // Subscription has been cancelled
  EXPIRED       // Subscription period has ended
  TRIAL         // Subscription is in trial period
  PAST_DUE      // Payment is past due (for future Stripe use)
  PENDING       // Subscription is pending activation
  GRACE_PERIOD  // In grace period after failed payment/expiry
}

enum SubscriptionTier {
  BASIC
  ESSENTIAL
  PROFESSIONAL
  ENTERPRISE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  FILLED
}

enum JobContractType {
  FULL_TIME
  PART_TIME
  CDI
  CDD
  INTERNSHIP
  REPLACEMENT
  TEMPORARY
  FREELANCE
}

// Used for job matching/search (aligned with educator availability UI).
enum JobEmploymentType {
  FULL_TIME
  PART_TIME
  REPLACEMENT
}

enum ServiceCategory {
  CLEANING
  IT_SUPPORT
  MAINTENANCE
  CONSULTING
  TRAINING
  OTHER
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
  SHORTLISTED
  INTERVIEW
  OFFER
  HIRED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContentType {
  VIDEO
  DOCUMENT
  QUIZ
  TEXT
  IMAGE
}

enum LessonStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum QuizType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  ESSAY
  MATCHING
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum ConversationType {
  DIRECT
  GROUP
  SUPPORT
}

enum TranslationStatus {
  PENDING
  MT_DONE
  REVIEWED
  APPROVED
}

enum InquiryStatus {
  NEW
  PENDING
  CONTACTED
  QUOTED
  FULFILLED
  DECLINED
  CANCELLED
}

// Tracks whether a vendor (supplier/service provider) considers a daycare an active client
// (used for discount termination workflows when daycares churn).
enum VendorClientReason {
  NEW
  TRIAL
  CONTRACT
  PAUSED
  TERMINATED
}

enum SubscriptionRequestStatus {
  PENDING           // Just submitted, awaiting review
  UNDER_REVIEW      // Admin is reviewing
  INVOICE_SENT      // Invoice has been sent to customer
  PAYMENT_PENDING   // Waiting for payment confirmation
  PAYMENT_RECEIVED  // Payment confirmed
  ACTIVATED         // Subscription created and activated
  DECLINED          // Request was declined
  CANCELLED         // Customer cancelled the request
}

enum SubscriptionCancellationRequestStatus {
  PENDING    // Customer requested cancellation, awaiting admin action
  APPROVED   // Admin approved and processed the cancellation
  DECLINED   // Admin declined the cancellation request
  CANCELLED  // Request withdrawn/cancelled by customer (future use)
}

enum EducatorApprovalStatus {
  PENDING_REVIEW // Educator signed up, awaiting admin approval
  APPROVED       // Admin approved - educator can access the platform
  REJECTED       // Admin rejected - educator cannot access the platform
}

// Core Models
model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String?  @unique
  firstName String?
  lastName  String?
  role      UserRole

  // Additional fields for educators from onboarding guide
  phoneNumber          String?
  workExperience       String? // JSON string or text field
  education            String? // JSON string or text field
  certifications       String[] // Array of certifications
  skills               String[] // Array of skills
  availability         String? // Legacy: simple text availability information
  availabilitySettings Json?   // New: structured Calendly-style availability schedule
  cvUrl                String? // URL to CV document (legacy single document)
  documents            Json?   // Array of DocumentItem objects (up to 5 documents)
  shortBio             String? // Short bio/description for profile
  candidatePoolVisible        Boolean  @default(true) // Educator-controlled visibility in candidate pool
  availableForReplacement     Boolean  @default(false) // Educator opted in for short-notice replacement shifts
  availableForInternship      Boolean  @default(false) // Educator/student available for internship placements
  region               String? // Candidate location (e.g., canton/city)
  jobRole              String? // Candidate role/title (e.g., "Educator", "Assistant")
  jobRoles             String[] @default([]) // Candidate roles/titles for multi-role matching
  cities               String[] @default([]) // Candidate cities for multi-city matching

  // Avatar asset relation
  avatarAssetId String?
  avatarAsset   Asset?  @relation("UserAvatar", fields: [avatarAssetId], references: [id])

  // Cover image asset relation (educator profile cover)
  coverAssetId String?
  coverAsset   Asset?  @relation("UserCover", fields: [coverAssetId], references: [id])

  // CV document asset relation (educator profile CV)
  cvAssetId String?
  cvAsset   Asset?  @relation("UserCV", fields: [cvAssetId], references: [id])

  // Stripe integration
  stripeCustomerId String? @unique

  // Activity tracking
  lastActiveAt DateTime?
  isActive     Boolean   @default(true)
  deactivatedAt DateTime?
  deactivatedReasonCode String?
  deactivatedReasonText String? @db.Text

  // Educator approval workflow
  approvalStatus  EducatorApprovalStatus? // Only set for EDUCATOR role
  approvalNotes   String?                 @db.Text // Admin rejection reason
  approvedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contactInfo            UserContactInfo?
  organizations          UserOrganization[]
  applications           JobApplication[]
  subscriptions          UserSubscription[]
  mainSubscriptions      Subscription[] // Main subscription model
  subscriptionRequests   SubscriptionRequest[] // Subscription requests
  subscriptionCancellationRequests SubscriptionCancellationRequest[] // Subscription cancellation requests
  licenses               License[]

  // E-Learning relations
  courseEnrollments CourseEnrollment[]
  certificates      Certificate[]
  courseDiscussions CourseDiscussion[]
  discussionReplies DiscussionReply[]

  // Enhanced messaging relations
  conversations    ConversationParticipant[]
  sentMessages     Message[]                 @relation("MessageSender")
  receivedMessages Message[]                 @relation("MessageReceiver")

  // User activity tracking
  activities UserActivity[] @relation("UserActivity")

  // Content moderation relations
  reportedContent   ContentModeration[] @relation("ContentReporter")
  moderatedContent  ContentModeration[] @relation("ContentModerator")
  moderationActions ModerationAction[]  @relation("ModerationActions")

  // Email notification relations
  emailLogs               EmailLog[]                   @relation("EmailLogs")
  notificationPreferences UserNotificationPreferences? @relation("NotificationPreferences")

  // New admin features relations
  contentItems            ContentItem[]      @relation("ContentUploader")
  policyAlerts            PolicyAlert[]      @relation("PolicyAlertCreator")
  auditLogs               AuditLog[]         @relation("AuditLogActor")
  platformSettingsUpdates PlatformSettings[] @relation("PlatformSettingsUpdater")
  apiKeys                 ApiKey[]           @relation("ApiKeyCreator")
  webhooks                Webhook[]          @relation("WebhookCreator")

  // Support ticket relations
  supportTickets         SupportTicket[]  @relation("UserSupportTickets")
  assignedTickets        SupportTicket[]  @relation("AssignedSupportTickets")
  ticketResponses        TicketResponse[] @relation("UserTicketResponses")

  // Calendar event relations
  calendarEvents         CalendarEvent[]  @relation("UserCalendarEvents")

  // Vendor client management (discount terminations)
  vendorClientMarks VendorClient[]

  // Parent lead ownership (links enquiries to parent accounts)
  parentLeads ParentLead[] @relation("UserParentLeads")

  // Structured educator profile items
  workExperienceItems EducatorWorkExperience[]
  educationItems      EducatorEducation[]
  certificationItems  EducatorCertification[]

  // Mailing custom list memberships
  mailingCustomListMemberships MailingCustomListMember[]

  // Replacement staffing relations
  replacementRequests  ReplacementRequest[]  @relation("UserReplacementRequests")
  replacementMatches   ReplacementMatch[]    @relation("EducatorReplacementMatches")

  // Intern pool relations
  internPoolRequests      InternPoolRequest[]      @relation("UserInternPoolRequests")
  internPoolApplications  InternPoolApplication[]  @relation("InternPoolApplications")

  // In-app notifications
  notifications        Notification[]        @relation("UserNotifications")

  // Per-day login activity (used for activity heatmap)
  activityLogs         UserActivityLog[]     @relation("UserActivityLogs")

  @@map("users")
}

// User contact info is intentionally separated from the authentication email.
// This allows a user to publish/share a "contact" email without changing the
// email used for authentication (User.email / AppUser.email / Clerk).
model UserContactInfo {
  id        String   @id @default(uuid())
  userId    String   @unique
  contactEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_contact_infos")
}

model EducatorWorkExperience {
  id              String   @id @default(uuid())
  userId          String
  jobTitle        String
  institutionName String
  startDate       String?
  endDate         String?
  descriptionPoints String[]
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("educator_work_experiences")
}

model EducatorEducation {
  id              String   @id @default(uuid())
  userId          String
  degree          String
  institutionName String
  graduationYear  String?
  description     String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("educator_educations")
}

model EducatorCertification {
  id                  String   @id @default(uuid())
  userId              String
  name                String
  issuingOrganization String?
  issueDate           String?
  expiryDate          String?
  credentialUrl       String?
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("educator_certifications")
}

model Organization {
  id          String           @id @default(uuid())
  name        String
  type        OrganizationType
  region      String?
  description String?
  vatNumber   String?

  // Additional fields from onboarding guide
  contactPerson        String?
  contactEmail         String? // Public contact email (falls back to user auth email if unset)
  phoneNumber          String?
  canton               String? // Legacy single canton field
  city                 String? // City where the organization is located
  regionsServed        String[] // Multiple cantons/regions served
  languages            String[] // Languages spoken/offered
  capacity             Int? // For foundations - number of children
  pedagogy             String[] // Educational approaches for foundations
  productCategory      String? // For suppliers - legacy single category
  productCategories    String[] @default([]) // For suppliers - new flexible category tags
  serviceType          String? // For service providers
  minimumOrderQuantity Int? // For suppliers
  directOrderLink      String? // For suppliers
  catalogUrl           String? // For suppliers
  websiteUrl           String? // Public website (all org types)
  serviceCategories    String[] // For service providers
  deliveryType         String? // On-site, Remote, Hybrid for service providers
  bookingLink          String? // For service providers

  // Foundation shortlist — stored as JSON array of User IDs; avoids a join table
  savedCandidateIds Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)

  // Asset relations
  logoAssetId  String?
  logoAsset    Asset?  @relation("OrganizationLogo", fields: [logoAssetId], references: [id])
  coverAssetId String?
  coverAsset   Asset?  @relation("OrganizationCover", fields: [coverAssetId], references: [id])

  // Relations
  members          UserOrganization[]
  products         Product[]
  catalogs         Catalog[]
  serviceProviders ServiceProvider[]
  jobListings      JobListing[]
  subscriptions    Subscription[]
  orders           Order[]
  serviceRequests  ServiceRequest[]
  profileDocuments OrganizationDocument[]

  // Foundation-specific relations
  leadResponses    FoundationLeadResponse[] @relation("FoundationLeadResponses")
  calendarEvents   CalendarEvent[]          @relation("OrganizationCalendarEvents")

  // Inquiry relations
  sentInquiries     Inquiry[] @relation("InquiryBuyer")    // Inquiries this org has sent
  receivedInquiries Inquiry[] @relation("InquirySupplier") // Inquiries this org has received (suppliers)

  // Subscription request relations
  subscriptionRequests SubscriptionRequest[]
  subscriptionCancellationRequests SubscriptionCancellationRequest[]

  // Promo codes for suppliers and service providers
  promoCodes PromoCode[]

  // Vendor client relationships (discount termination workflow)
  vendorClientsAsVendor VendorClient[] @relation("VendorClientVendor")
  vendorClientsAsOrg    VendorClient[] @relation("VendorClientOrg")

  // Replacement staffing
  replacementRequests ReplacementRequest[] @relation("FoundationReplacementRequests")

  // Intern pool
  internPoolRequests InternPoolRequest[] @relation("FoundationInternPoolRequests")

  @@map("organizations")
}


model UserOrganization {
  userId         String
  organizationId String
  role           UserRole
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@index([userId, createdAt]) // Optimize primary organization lookup in auth guard
  @@map("user_organizations")
}

// Vendor <-> daycare relationship for discounts/active client tracking
model VendorClient {
  id             String             @id @default(uuid())
  vendorId       String
  orgId          String
  isActive       Boolean            @default(true)
  reason         VendorClientReason?
  note           String?
  markedByUserId String?
  markedAt       DateTime           @default(now())
  deactivatedAt  DateTime?
  lastAdminNotifiedAt DateTime?

  // Relations
  vendor   Organization @relation("VendorClientVendor", fields: [vendorId], references: [id], onDelete: Cascade)
  org      Organization @relation("VendorClientOrg", fields: [orgId], references: [id], onDelete: Cascade)
  markedBy User?        @relation(fields: [markedByUserId], references: [id], onDelete: SetNull)

  @@unique([vendorId, orgId], name: "vendorId_orgId")
  @@index([vendorId])
  @@index([orgId])
  @@map("vendor_clients")
}

// Promo Codes for Product Suppliers and Service Providers
// Display-only promo codes shown on supplier/provider profiles
model PromoCode {
  id             String   @id @default(uuid())
  code           String   // The promo code string (e.g., "SAVE20")
  description    String?  // Optional description of the promo
  discount       String   // Free text discount (e.g., "20% off", "Free shipping", "CHF 10 off")
  isActive       Boolean  @default(true) // Whether the promo code is displayed
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders       Order[]      @relation("OrderPromoCode")

  @@unique([code, organizationId])
  @@index([organizationId])
  @@index([isActive])
  @@map("promo_codes")
}

// Organization Profile Documents (Catalogs, Company Profiles, etc.)
model OrganizationDocument {
  id             String   @id @default(uuid())
  organizationId String
  assetId        String
  documentType   String   @default("CATALOG") // CATALOG, COMPANY_PROFILE, BROCHURE, PRICE_LIST
  title          String?
  description    String?
  displayOrder   Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset        Asset        @relation("OrganizationDocumentAsset", fields: [assetId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([documentType])
  @@map("organization_documents")
}

model Asset {
  id           String    @id @default(uuid())
  kind         AssetKind
  filename     String
  publicUrl    String
  storageKey   String
  mimeType     String?
  size         Int?
  uploadedById String
  etag         String? // ETag from R2/S3 for verification
  checksum     String? // SHA-256 checksum (base64) for integrity
  version      Int       @default(1) // Version for response/schema changes

  // Content categorization fields
  category       String? // HR_DOCUMENT, ELEARNING, STATE_POLICY, etc. (content type)
  contentCategory String? // Child Development, Onboarding, Education Policy, etc. (actual category)
  title       String?
  description String?
  metadata    Json? // Legacy/flexible metadata (deprecated, use typed fields below)

  // Typed content fields (replaces JSON metadata)
  contentType    String? // COURSE, VIDEO, PDF, LINK (for e-learning)
  language       String? // EN, FR, DE
  accessRoles    String[] @default([]) // Array of UserRole values
  status         String?  @default("Draft") // Draft, Published, Archived, etc.
  contentPreview String? // Short preview/description for listing
  tags           String[] @default([]) // Searchable tags

  // E-Learning specific fields
  duration        String? // e.g., "2 hours, 30 minutes"
  lessons         Int? // Number of lessons (for COURSE type)
  videoSourceType String? // 'upload' or 'url' (for VIDEO type)

  // HR Document specific fields
  fileType      String? // PDF, DOCX, XLSX, etc.
  versionNumber String? // Document version
  effectiveDate DateTime? // When document becomes effective
  reviewDate    DateTime? // Next review date

  // State Policy specific fields
  country        String? // Switzerland, Germany, Austria, France
  region         String? // Canton/State/Region
  policyType     String? // Regulation, Guideline, Standard, Directive, Law
  isCritical     Boolean   @default(false) // Critical policy flag
  expirationDate DateTime? // Policy expiration date
  externalLink   String? // Link to official policy document

  // Canton policy crawler integration fields (null = manually uploaded)
  crawlSourceId     Int?
  officialUrl       String?   // Canonical URL on official site (separate from publicUrl)
  contentHash       String?   // Content hash for change detection
  lastCrawledAt     DateTime?
  crawlStatus       String?   // pending_review, approved, rejected, manual, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - after migration, points to AppUser
  uploader AppUser @relation("AssetUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  // Organization asset relations
  organizationLogos  Organization[] @relation("OrganizationLogo")
  organizationCovers Organization[] @relation("OrganizationCover")

  // User asset relations
  userAvatars User[] @relation("UserAvatar")
  userCovers  User[] @relation("UserCover")
  userCVs     User[] @relation("UserCV")

  // Product relations
  products Product[]

  // Catalog relations
  catalogPdfs Catalog[] @relation("CatalogPdf")
  catalogCsvs Catalog[] @relation("CatalogCsv")

  // Organization document relations
  organizationDocuments OrganizationDocument[] @relation("OrganizationDocumentAsset")

  // Frontend customization relations
  frontendLogos    FrontendSettings[] @relation("FrontendLogo")
  frontendFavicons FrontendSettings[] @relation("FrontendFavicon")
  frontendOgImages FrontendSettings[] @relation("FrontendOgImage")
  adminLogos       FrontendSettings[] @relation("AdminLogo")
  adminFavicons    FrontendSettings[] @relation("AdminFavicon")
  sidebarLogos     FrontendSettings[] @relation("SidebarLogo")

  // Crawler relations
  crawlSource CantonSource? @relation(fields: [crawlSourceId], references: [id], onDelete: SetNull)

  @@index([storageKey])
  @@index([etag])
  @@index([category])
  @@index([contentCategory])
  @@index([contentType])
  @@index([language])
  @@index([status])
  @@index([country])
  @@index([region])
  @@index([isCritical])
  @@index([crawlSourceId])
  @@index([crawlStatus])
  @@map("assets")
}

// =====================================
// Canton Policy Crawler
// =====================================

model Canton {
  id          Int      @id @default(autoincrement())
  code        String   @unique // 'VD', 'FR', 'ZH'
  name        String
  nameDe      String?
  nameIt      String?
  nameFr      String?
  defaultLang String   @default("de")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sources     CantonSource[]

  @@map("cantons")
}

model CantonSource {
  id                 Int      @id @default(autoincrement())
  cantonId           Int
  canton             Canton   @relation(fields: [cantonId], references: [id])

  label              String
  url                String
  sourceType         String   @default("landing") // landing, directives, laws, federal, etc.
  renderType         String   @default("static")  // static, dynamic
  cssSelector        String?

  isActive           Boolean  @default(true)
  crawlFrequencyDays Int      @default(7)
  maxSubpageDepth    Int      @default(0)  // 0 = only source page, 1 = source + direct subpages, etc.
  maxCrawlPages      Int      @default(100) // Max pages to crawl per session
  maxCrawlDurationSec Int     @default(300) // Max crawl duration in seconds (5 min default)
  crawlDelayMs       Int      @default(200) // Delay between page fetches in ms

  lastCrawlAt        DateTime?
  lastCrawlStatus    String?  // success, failed, partial
  lastCrawlError     String?
  nextCrawlAt        DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  crawlHistory       PolicyCrawlHistory[]
  crawledAssets      Asset[]

  @@index([cantonId])
  @@index([isActive, nextCrawlAt])
  @@map("canton_sources")
}

model PolicyCrawlHistory {
  id          Int          @id @default(autoincrement())
  assetId     String
  sourceId    Int
  source      CantonSource @relation(fields: [sourceId], references: [id])

  contentHash String
  fetchedAt   DateTime  @default(now())
  changeType  String?   // new, updated, unchanged
  diffSummary String?

  // Internal indexing (optional - can be large)
  contentText String?   @db.Text

  @@index([assetId])
  @@index([sourceId, fetchedAt])
  @@map("policy_crawl_history")
}

model Product {
  id                 String                     @id @default(uuid())
  title              String
  subtitle           String?
  description        String?
  price              Float?
  priceCurrency      String?                    @default("CHF")
  category           String? // Keep for backward compatibility
  primaryCategory    String?
  categories         String[]                   @default([]) // Flexible categories as tags
  tags               String[]                   @default([])
  productHighlights  String[]                   @default([])
  unitOfMeasure      String?
  status             String                     @default("ACTIVE") // ACTIVE, INACTIVE, PENDING, REJECTED
  availabilityStatus ProductAvailabilityStatus  @default(ACTIVE)
  isActive           Boolean                    @default(true)
  sku                String?
  vendorSku          String?
  ean                String?
  minOrderQuantity   Int?
  maxOrderQuantity   Int?
  stockStatus        String?
  deliveryLeadTimeDays Int?
  restockCadence     String?
  usageNotes         String?
  packagingDetails   String?
  materials          String?
  complianceTags     String[]                   @default([])
  allergens          String[]                   @default([])
  ageRanges          String[]                   @default([])
  deliveryMethods    String[]                   @default([])
  deliveryFees       Json?
  supportedCantons   String[]                   @default([])
  visibilityStart    DateTime?
  visibilityEnd      DateTime?
  volumePricing      Json?
  variants           Json?
  supplierId         String
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  // Asset references
  imageAssetId     String?
  galleryAssetIds  String[] @default([])
  specSheetAssetId String?
  msdsAssetId      String?

  imageAsset Asset? @relation(fields: [imageAssetId], references: [id])

  // Relations
  supplier Organization @relation(fields: [supplierId], references: [id])
  orders   OrderItem[]

  @@map("products")
}

enum ProductAvailabilityStatus {
  ACTIVE
  INACTIVE
  DRAFT
  OUT_OF_STOCK
}

model Catalog {
  id          String   @id @default(uuid())
  title       String
  description String?
  supplierId  String
  pdfAssetId  String?
  csvAssetId  String?
  isActive    Boolean  @default(true)
  uploadedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Asset relations
  pdfAsset Asset? @relation("CatalogPdf", fields: [pdfAssetId], references: [id])
  csvAsset Asset? @relation("CatalogCsv", fields: [csvAssetId], references: [id])

  // Relations
  supplier Organization @relation(fields: [supplierId], references: [id])

  @@map("catalogs")
}

model Service {
  id           String          @id @default(uuid())
  title        String
  description  String?
  category     ServiceCategory // Keep for backward compatibility
  categories   String[]        @default([]) // New flexible categories as tags
  price        Float?
  priceInfo    String?
  availability String?
  deliveryType String?         @default("On-site")
  tags         String[]        @default([])
  imageUrl     String?
  isActive     Boolean         @default(true)
  providerId   String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  provider ServiceProvider  @relation(fields: [providerId], references: [id])
  requests ServiceRequest[]

  @@map("services")
}

model ServiceProvider {
  id             String   @id @default(uuid())
  organizationId String   @unique
  deliveryType   String? // "On-site", "Remote", "Hybrid"
  bookingLink    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  services     Service[]

  @@map("service_providers")
}

model JobListing {
  id               String          @id @default(uuid())
  title            String
  description      String?
  requirements     String[]        @default([])
  benefits         String[]        @default([])
  responsibilities String[]        @default([])
  qualifications   String[]        @default([])
  location         String?
  salary           String?
  salaryRange      String?
  contractType     JobContractType @default(FULL_TIME)
  // Search/matching field (separate from contractType: e.g. CDI can still be FULL_TIME)
  employmentType   JobEmploymentType @default(FULL_TIME)
  // Structured schedule preferences for PART_TIME/REPLACEMENT roles.
  // Stored as JSON for flexibility; validated at API boundary.
  workSchedule     Json?
  startDate        DateTime?
  status           JobStatus       @default(DRAFT)
  foundationId     String
  publishedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  foundation   Organization     @relation(fields: [foundationId], references: [id])
  applications JobApplication[]

  @@map("job_listings")
}

model JobApplication {
  id           String            @id @default(uuid())
  jobListingId String
  candidateId  String
  coverLetter  String?
  cvUrl        String?
  cvAssetId    String?
  status       ApplicationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relations
  jobListing JobListing @relation(fields: [jobListingId], references: [id])
  candidate  User       @relation(fields: [candidateId], references: [id])

  @@unique([jobListingId, candidateId])
  @@map("job_applications")
}

model Subscription {
  id                   String             @id @default(uuid())
  
  // Owner (one of these must be set)
  userId               String? // Optional user ID for user-based subscriptions
  organizationId       String? // Optional organization ID for org-based subscriptions
  
  // Plan Details
  planId               String
  tier                 SubscriptionTier
  
  // Status
  status               SubscriptionStatus @default(PENDING)
  
  // Period Management
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialStart           DateTime?          @map("trial_start")
  trialEnd             DateTime?          @map("trial_end")
  pausedAt             DateTime?          @map("paused_at")
  pausedUntil          DateTime?          @map("paused_until")
  
  // Cancellation
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  cancellationReason   String?            @map("cancellation_reason")
  
  // Stripe Integration (prepared for future)
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  
  // Manual Management Fields
  isManual             Boolean            @default(true) @map("is_manual")
  activatedBy          String?            @map("activated_by")
  activatedAt          DateTime?          @map("activated_at")
  
  // Grace Period
  gracePeriodEnd       DateTime?          @map("grace_period_end")
  
  // Metadata
  notes                String?            @db.Text
  metadata             Json?
  
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  // Relations
  user                User?                 @relation(fields: [userId], references: [id])
  organization        Organization?         @relation(fields: [organizationId], references: [id])
  plan                SubscriptionPlan      @relation(fields: [planId], references: [id])
  transactions        BillingTransaction[]
  actions             SubscriptionAction[]
  schedules           SubscriptionSchedule[]
  subscriptionNotes   SubscriptionNote[]
  subscriptionRequest SubscriptionRequest?  // Link to original request
  cancellationRequests SubscriptionCancellationRequest[]

  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([isManual], map: "subscriptions_is_manual_idx")
  @@map("subscriptions")
}

model Order {
  id             String   @id @default(uuid())
  organizationId String
  subtotalAmount Float?
  promoCodeId    String?
  promoCodeCode  String?  @map("promoCode")
  discountType   String?
  discountValue  Float?
  discountAmount Float    @default(0)
  totalAmount    Float
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  appliedPromoCode PromoCode? @relation("OrderPromoCode", fields: [promoCodeId], references: [id], onDelete: SetNull)
  items        OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  // Relations
  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model ServiceRequest {
  id             String    @id @default(uuid())
  organizationId String
  serviceId      String
  description    String?
  status         String    @default("PENDING")
  requestedAt    DateTime  @default(now())
  scheduledAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])

  @@map("service_requests")
}

// Supplier Inquiry Model - for suppliers who don't sell directly on platform
model Inquiry {
  id             String        @id @default(uuid())
  organizationId String        // The foundation/buyer making the inquiry
  supplierId     String        // The supplier receiving the inquiry
  
  // Inquiry details
  subject        String?
  message        String
  productInterest String?      // Optional: specific product they're interested in
  quantity       Int?          // Optional: estimated quantity needed
  budget         String?       // Optional: budget range
  urgency        String?       // Optional: LOW, MEDIUM, HIGH, URGENT
  
  // Contact preferences
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  preferredContactMethod String? // EMAIL, PHONE, PLATFORM
  
  // Status tracking
  status         InquiryStatus @default(NEW)
  supplierNotes  String?       // Internal notes for supplier
  responseMessage String?      // Supplier's response to the inquiry
  quotedAmount   Float?        // If supplier provides a quote
  
  // Timestamps
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  respondedAt    DateTime?     // When supplier first responded
  fulfilledAt    DateTime?     // When inquiry was fulfilled/converted

  // Relations
  organization   Organization  @relation("InquiryBuyer", fields: [organizationId], references: [id])
  supplier       Organization  @relation("InquirySupplier", fields: [supplierId], references: [id])

  @@index([supplierId, status])
  @@index([organizationId])
  @@index([createdAt])
  @@map("inquiries")
}

model ParentLead {
  id           String  @id @default(uuid())
  parentName   String
  parentEmail  String
  parentPhone  String?
  parentUserId String?
  childName    String
  childAge     Int
  message      String?
  foundationId String?

  // Additional fields from onboarding guide
  preferredLocation   String? // Preferred canton/location
  preferredCities     String[] // Preferred cities within the canton (multiple allowed)
  preferredLanguages  String[] // Preferred languages
  specialRequirements String? // Special needs or requirements

  // Additional fields for lead management
  source String? // Source of the lead (website, referral, etc.)

  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  parentUser          User?                    @relation("UserParentLeads", fields: [parentUserId], references: [id], onDelete: SetNull)
  foundationResponses FoundationLeadResponse[]

  @@index([status])
  @@index([foundationId])
  @@index([parentUserId])
  @@map("parent_leads")
}

// Translation tables for i18n

// Static UI translations (buttons, labels, messages)
model StaticTranslation {
  namespace   String
  key         String
  lang        String
  value       String    @db.Text
  updatedAt   DateTime  @updatedAt
  updatedBy   String?
  createdAt   DateTime  @default(now())
  needsReview Boolean   @default(false)
  reviewedBy  String?
  reviewedAt  DateTime?

  @@id([namespace, key, lang])
  @@index([namespace, lang])
  @@index([key])
  @@map("static_translations")
}

// Enhanced Entity Translation with lifecycle states
model EntityTranslation {
  entityType   String
  entityId     String
  lang         String
  field        String
  text         String            @db.Text
  origin       String            @default("machine")
  status       TranslationStatus @default(PENDING)
  verified     Boolean           @default(false)
  sourceHash   String
  updatedAt    DateTime          @updatedAt
  translatedAt DateTime?
  mtProvider   String?
  approvedAt   DateTime?
  approvedBy   String?
  reviewedAt   DateTime?
  reviewedBy   String?

  @@id([entityType, entityId, lang, field])
  @@index([entityType, lang])
  @@index([status, updatedAt])
  @@map("entity_translations")
}

model EntitySource {
  entityType String
  entityId   String
  sourceLang String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@id([entityType, entityId])
  @@map("entity_sources")
}

// Translation Memory: Cache MT results to avoid re-translating
model TranslationMemory {
  id             String   @id @default(cuid())
  sourceTextHash String
  sourceLang     String
  targetLang     String
  translatedText String   @db.Text
  mtProvider     String
  usageCount     Int      @default(1)
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime @updatedAt

  @@unique([sourceTextHash, sourceLang, targetLang])
  @@index([sourceLang, targetLang])
  @@map("translation_memory")
}

// Track translation releases for cache-busting
model TranslationRelease {
  id          String   @id @default(cuid())
  version     String   @unique
  description String?
  createdBy   String?
  createdAt   DateTime @default(now())
  isActive    Boolean  @default(false)

  @@index([isActive, createdAt])
  @@map("translation_releases")
}

// Audit log for translation changes
model TranslationAuditLog {
  id         String   @id @default(cuid())
  type       String // 'static' | 'dynamic'
  namespace  String?
  entityType String?
  entityId   String?
  key        String?
  field      String?
  lang       String
  action     String // 'create' | 'update' | 'delete' | 'approve' | 'review'
  oldValue   String?  @db.Text
  newValue   String?  @db.Text
  userId     String
  createdAt  DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@map("translation_audit_logs")
}

// Track MT API usage and costs
model MTCostTracking {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  provider   String
  sourceLang String
  targetLang String
  characters Int
  cost       Decimal  @db.Decimal(10, 4)
  jobCount   Int      @default(0)

  @@unique([date, provider, sourceLang, targetLang])
  @@index([date, provider])
  @@map("mt_cost_tracking")
}

// Subscription System Models
model Plan {
