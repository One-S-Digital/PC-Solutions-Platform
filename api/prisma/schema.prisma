// User Activity Tracking
model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  action    String // e.g., "LOGIN", "PROFILE_UPDATE", "PASSWORD_CHANGE"
  details   Json? // Additional context about the action
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Relations
  user User @relation("UserActivity", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activities")
}

// Per-day login activity log — one row per (user, UTC calendar date)
// Written fire-and-forget from auth guard on every authenticated request.
model UserActivityLog {
  id     String   @id @default(uuid())
  userId String
  date   DateTime // midnight UTC of the calendar day

  user User @relation("UserActivityLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("user_activity_logs")
}

// Content Moderation System
model ContentModeration {
  id          String  @id @default(uuid())
  contentId   String // ID of the content being moderated
  contentType String // PRODUCT, JOB_LISTING, SERVICE, ORGANIZATION, USER_PROFILE
  status      String  @default("PENDING") // PENDING, APPROVED, REJECTED, FLAGGED
  priority    String  @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  reason      String? // Reason for moderation/flagging
  notes       String? // Additional notes from moderator

  // User tracking
  reporterId  String? // User who reported/flagged the content
  moderatorId String? // Admin who moderated the content

  // Timestamps
  createdAt   DateTime  @default(now())
  flaggedAt   DateTime?
  moderatedAt DateTime?

  // Relations
  reporter  User?              @relation("ContentReporter", fields: [reporterId], references: [id])
  moderator User?              @relation("ContentModerator", fields: [moderatorId], references: [id])
  actions   ModerationAction[]

  @@unique([contentId])
  @@map("content_moderation")
}

model ModerationAction {
  id          String   @id @default(uuid())
  contentId   String
  contentType String
  action      String // APPROVE, REJECT, FLAG, REQUEST_CHANGES
  reason      String?
  notes       String?
  moderatorId String
  createdAt   DateTime @default(now())

  // Relations
  moderator  User              @relation("ModerationActions", fields: [moderatorId], references: [id])
  moderation ContentModeration @relation(fields: [contentId], references: [contentId])

  @@map("moderation_actions")
}

// Email Notification System
model EmailTemplate {
  id          String   @id @default(uuid())
  name        String
  event       String   @unique // Event identifier (e.g., 'account_verification')
  subject     String
  htmlContent String
  textContent String
  variables   String[] // Template variables
  category    String // Category for grouping templates
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("email_templates")
}

model EmailLog {
  id         String   @id @default(uuid())
  userId     String?
  event      String
  recipient  String
  templateId String?
  messageId  String? // SendGrid message ID
  status     String // sent, delivered, opened, clicked, bounced, failed
  payload    Json? // Template variables used
  error      String? // Error message if failed
  createdAt  DateTime @default(now())

  // Relations
  user User? @relation("EmailLogs", fields: [userId], references: [id])

  @@map("email_logs")
}

model ScheduledEmail {
  id          String   @id @default(uuid())
  event       String
  recipient   String
  payload     Json
  scheduledAt DateTime
  status      String   @default("pending") // pending, sent, failed
  createdAt   DateTime @default(now())

  @@map("scheduled_emails")
}

model UserNotificationPreferences {
  id                 String  @id @default(uuid())
  userId             String  @unique
  emailNotifications Boolean @default(true)

  // Category preferences
  authentication    Boolean @default(true)
  userManagement    Boolean @default(true)
  jobRecruitment    Boolean @default(true)
  messaging         Boolean @default(true)
  marketplace       Boolean @default(true)
  leadManagement    Boolean @default(true)
  subscription      Boolean @default(true)
  contentModeration Boolean @default(true)
  systemAdmin       Boolean @default(true)
  marketing         Boolean @default(true)

  // Mailing list opt-out — only true when user explicitly unsubscribes
  mailingListOptOut  Boolean @default(false) @map("mailing_list_opt_out")

  // Frequency settings
  frequency String @default("immediate") // immediate, daily, weekly

  // Quiet hours
  quietHoursEnabled Boolean @default(false)
  quietHoursStart   String? // HH:MM format
  quietHoursEnd     String? // HH:MM format

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation("NotificationPreferences", fields: [userId], references: [id])

  @@map("user_notification_preferences")
}

// Subscription Management System
model SubscriptionPlan {
  id            String   @id @default(uuid())
  
  // Basic Info
  name          String
  code          String?  @unique // BASIC, ESSENTIAL, PROFESSIONAL, ENTERPRISE
  description   String   @db.Text
  
  // Pricing
  price         Float
  currency      String   @default("CHF")
  billingPeriod String   @default("monthly") @map("billing_period") // monthly, quarterly, yearly
  
  // Features
  features      String[] // Array of feature names
  limits        Json     // Usage limits as JSON { "parentEnquiries": 15, "teamMembers": 5, ... }
  
  // Access Control
  allowedRoles  String[] @default([]) @map("allowed_roles") // Which user roles can subscribe
  
  // Trial
  trialDays     Int      @default(0) @map("trial_days")
  
  // Display
  isActive      Boolean  @default(true) @map("is_active")
  isPopular     Boolean  @default(false) @map("is_popular")
  displayOrder  Int      @default(0) @map("display_order")
  
  // Stripe (prepared for future)
  stripePriceId   String? @map("stripe_price_id")
  stripeProductId String? @map("stripe_product_id")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  subscriptions          Subscription[]
  subscriptionRequests   SubscriptionRequest[]

  @@map("subscription_plans")
}

// Subscription Request Model - Manages the request lifecycle before subscription activation
model SubscriptionRequest {
  id                String   @id @default(uuid())
  
  // Requester (one must be set)
  userId            String?
  organizationId    String?
  
  // Request Details
  planId            String
  tier              SubscriptionTier
  billingPeriod     String   @default("monthly") @map("billing_period") // monthly, quarterly, yearly
  
  // Contact Information (for reaching out)
  contactName       String?  @map("contact_name")
  contactEmail      String   @map("contact_email")
  contactPhone      String?  @map("contact_phone")
  preferredContact  String?  @default("email") @map("preferred_contact") // email, phone
  
  // Additional Context
  message           String?  @db.Text
  notes             String?  @db.Text  // Admin notes
  
  // Status Workflow
  status            SubscriptionRequestStatus @default(PENDING)
  
  // Invoice/Payment Tracking
  invoiceNumber     String?  @map("invoice_number")
  invoiceSentAt     DateTime? @map("invoice_sent_at")
  invoiceAmount     Float?   @map("invoice_amount")
  invoiceCurrency   String?  @default("CHF") @map("invoice_currency")
  paymentReceivedAt DateTime? @map("payment_received_at")
  paymentReference  String?  @map("payment_reference")
  
  // Subscription Link (when activated)
  subscriptionId    String?  @unique @map("subscription_id")
  
  // Timestamps
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  reviewedAt        DateTime? @map("reviewed_at")
  reviewedBy        String?  @map("reviewed_by")
  processedAt       DateTime? @map("processed_at")
  processedBy       String?  @map("processed_by")
  declinedAt        DateTime? @map("declined_at")
  declinedBy        String?  @map("declined_by")
  declineReason     String?  @db.Text @map("decline_reason")
  
  // Relations
  user              User?         @relation(fields: [userId], references: [id])
  organization      Organization? @relation(fields: [organizationId], references: [id])
  plan              SubscriptionPlan @relation(fields: [planId], references: [id])
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([organizationId])
  @@map("subscription_requests")
}

// Subscription Cancellation Request Model - User requests cancellation for admin processing
model SubscriptionCancellationRequest {
  id              String   @id @default(uuid())

  // Related subscription
  subscriptionId  String   @map("subscription_id")

  // Requester context (one may be set; kept for admin filtering)
  userId          String?  @map("user_id")
  organizationId  String?  @map("organization_id")

  // Customer-provided reason/context
  reason          String?  @db.Text

  // Workflow
  status          SubscriptionCancellationRequestStatus @default(PENDING)

  // Timestamps / processing metadata
  requestedAt     DateTime @default(now()) @map("requested_at")
  processedAt     DateTime? @map("processed_at")
  processedBy     String?  @map("processed_by")
  notes           String?  @db.Text  // Admin notes

  // Relations
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id])
  organization    Organization? @relation(fields: [organizationId], references: [id])

  @@index([status])
  @@index([requestedAt])
  @@index([subscriptionId])
  @@index([userId])
  @@index([organizationId])
  @@map("subscription_cancellation_requests")
}

// Subscription Settings - Admin configurable settings for subscription management
model SubscriptionSettings {
  id                        String   @id @default(uuid())
  
  // Admin Notification Settings
  notificationEmail         String?  @map("notification_email") // Email to receive new request notifications
  enableEmailNotifications  Boolean  @default(true) @map("enable_email_notifications")
  
  // Default Settings
  defaultTrialDays          Int      @default(14) @map("default_trial_days")
  defaultGracePeriodDays    Int      @default(7) @map("default_grace_period_days")
  
  // Invoice Settings
  invoicePrefix             String   @default("INV-") @map("invoice_prefix")
  invoiceNextNumber         Int      @default(1001) @map("invoice_next_number")
  
  // Payment Terms
  paymentTermsDays          Int      @default(30) @map("payment_terms_days")
  
  // Response Time (for user communication)
  estimatedResponseHours    Int      @default(48) @map("estimated_response_hours")
  
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("subscription_settings")
}

// Subscription Action (Audit Log)
model SubscriptionAction {
  id             String   @id @default(uuid())
  subscriptionId String   @map("subscription_id")
  action         String   // CREATE, ACTIVATE, PAUSE, RESUME, CANCEL, RENEW, UPGRADE, DOWNGRADE, EXPIRE
  previousStatus String?  @map("previous_status")
  newStatus      String   @map("new_status")
  reason         String?
  notes          String?  @db.Text
  performedBy    String   @map("performed_by") // Admin user ID
  performedAt    DateTime @default(now()) @map("performed_at")
  metadata       Json?    // Additional context data
  
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  @@index([subscriptionId])
  @@index([performedAt])
  @@map("subscription_actions")
}

// Subscription Schedule (Future Actions)
model SubscriptionSchedule {
  id              String    @id @default(uuid())
  subscriptionId  String    @map("subscription_id")
  scheduledAction String    @map("scheduled_action") // ACTIVATE, CANCEL, PAUSE, RESUME, UPGRADE, DOWNGRADE
  scheduledDate   DateTime  @map("scheduled_date")
  targetPlanId    String?   @map("target_plan_id") // For upgrade/downgrade
  isProcessed     Boolean   @default(false) @map("is_processed")
  processedAt     DateTime? @map("processed_at")
  createdBy       String    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  @@index([scheduledDate, isProcessed])
  @@map("subscription_schedules")
}

// Subscription Note (Admin Notes)
model SubscriptionNote {
  id             String   @id @default(uuid())
  subscriptionId String   @map("subscription_id")
  note           String   @db.Text
  isInternal     Boolean  @default(true) @map("is_internal") // Internal admin note vs customer-visible
  createdBy      String   @map("created_by")
  createdAt      DateTime @default(now())
  
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  @@index([subscriptionId])
  @@map("subscription_notes")
}

model PricingTier {
  id            String   @id @default(uuid())
  role          UserRole @default(FOUNDATION)
  subscriptionTier SubscriptionTier @default(BASIC) @map("subscription_tier")
  name          String
  basePrice     Float
  currency      String   @default("CHF")
  billingPeriod String   @default("monthly") // monthly, yearly
  discounts     Json // Discount configuration as JSON
  isActive      Boolean  @default(true)
  displayOrder  Int      @default(0) @map("display_order")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([role])
  @@index([subscriptionTier])
  @@index([role, subscriptionTier])
  @@unique([role, subscriptionTier, billingPeriod])
  @@map("pricing_tiers")
}

model DynamicPricingRule {
  id                 String    @id @default(uuid())
  name               String
  conditions         Json // Rule conditions as JSON
  pricingAdjustments Json // Pricing adjustments as JSON
  isActive           Boolean   @default(true)
  validFrom          DateTime  @default(now())
  validUntil         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("dynamic_pricing_rules")
}

model FeatureFlag {
  id                String   @id @default(uuid())
  name              String
  description       String
  key               String   @unique // Unique feature identifier
  isActive          Boolean  @default(true)
  rolloutPercentage Int      @default(0) // 0-100
  targetSegments    String[] // User segments
  conditions        Json // Feature conditions as JSON
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("feature_flags")
}

model BillingTransaction {
  id                    String   @id @default(uuid())
  subscriptionId        String
  amount                Float
  currency              String   @default("CHF")
  status                String   @default("pending") // pending, succeeded, failed, refunded
  stripePaymentIntentId String?
  stripeChargeId        String?
  description           String
  metadata              Json? // Additional transaction data
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("billing_transactions")
}

// System Configuration Management
model SystemSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String
  category    String   @default("general")
  isEncrypted Boolean  @default(false)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model IntegrationConfig {
  id            String    @id @default(uuid())
  name          String
  type          String // auth, payment, email, storage, analytics, other
  provider      String
  isActive      Boolean   @default(true)
  configuration Json // Integration-specific configuration
  credentials   Json // Encrypted credentials
  webhookUrl    String?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("integration_configs")
}

model MaintenanceMode {
  id               String    @id @default(uuid())
  isEnabled        Boolean   @default(false)
  message          String
  allowedPaths     String[] // Paths that remain accessible during maintenance
  allowedRoles     String[] // User roles that remain accessible during maintenance
  estimatedEndTime DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("maintenance_mode")
}

model MaintenanceSchedule {
  id               String   @id @default(uuid())
  name             String
  description      String
  scheduledStart   DateTime
  scheduledEnd     DateTime
  isActive         Boolean  @default(true)
  notificationSent Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("maintenance_schedules")
}

// New Role Management Tables
model AppUser {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String?  @unique
  role      UserRole @default(PARENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets         Asset[]              @relation("AssetUploadedBy")
  roleHistory    AppUserRoleHistory[]
  createdCourses Course[]             @relation("CourseCreator")
}

model AppUserRoleHistory {
  id           BigInt    @id @default(autoincrement())
  userId       String
  previousRole UserRole?
  newRole      UserRole
  changedBy    String // clerkId of actor OR 'system/webhook'
  reason       String?
  changedAt    DateTime  @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Outbox {
  id        BigInt   @id @default(autoincrement())
  topic     String
  payload   Json
  attempts  Int      @default(0)
  nextRunAt DateTime @default(now())
  createdAt DateTime @default(now())
  lastError String?

  @@index([nextRunAt])
}

// Platform Settings and Configuration
model PlatformSettings {
  id                        String   @id @default(uuid())
  platformName              String   @default("ProCrèche Solutions Suisse")
  platformDescription       String?
  platformVersion           String   @default("1.0.0")
  maintenanceMode           Boolean  @default(false)
  maintenanceMessage        String? // Custom message during maintenance
  registrationEnabled       Boolean  @default(true)
  emailVerificationRequired Boolean  @default(true)
  maxFileUploadSize         Int      @default(10485760) // 10MB in bytes
  allowedFileTypes          String[] @default(["jpg", "jpeg", "png", "pdf", "doc", "docx"])
  sessionTimeout            Int      @default(3600) // 1 hour in seconds
  passwordMinLength         Int      @default(8)
  passwordRequireSpecial    Boolean  @default(true)
  twoFactorRequired         Boolean  @default(false)
  apiRateLimit              Int      @default(1000) // requests per hour
  backupFrequency           String   @default("daily") // daily, weekly, monthly
  logRetentionDays          Int      @default(90)
  revision                  Int      @default(1) // For optimistic locking
  updatedBy                 String? // User ID who made last update
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Relations
  updater User? @relation("PlatformSettingsUpdater", fields: [updatedBy], references: [id])

  @@map("platform_settings")
}

// Audit Logging for Compliance and Debugging
model AuditLog {
  id        String   @id @default(uuid())
  entity    String // e.g., "PolicyAlert", "ContentItem", "User"
  entityId  String // ID of the entity that was modified
  action    String // "create", "update", "delete", "upsert"
  actorId   String? // User ID who performed the action
  diff      Json? // Before/after snapshot
  metadata  Json? // Request context (IP, traceId, userAgent, etc.)
  createdAt DateTime @default(now())

  // Relations
  actor User? @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([entity, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

// System Monitoring and Health Checks
model SystemHealthCheck {
  id           String   @id @default(uuid())
  serviceName  String
  status       String // healthy, degraded, down
  responseTime Int? // milliseconds
  lastChecked  DateTime @default(now())
  errorMessage String?
  metadata     Json? // Additional health check data
  createdAt    DateTime @default(now())

  @@map("system_health_checks")
}

model SystemMetrics {
  id          String   @id @default(uuid())
  metricName  String
  metricValue Float
  unit        String? // bytes, seconds, count, etc.
  timestamp   DateTime @default(now())
  metadata    Json? // Additional metric data
  createdAt   DateTime @default(now())

  @@map("system_metrics")
}

model SystemAlert {
  id         String    @id @default(uuid())
  alertType  String // error, warning, info
  title      String
  message    String
  severity   String // low, medium, high, critical
  isResolved Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  metadata   Json? // Additional alert data
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("system_alerts")
}

// Content Management System
model ContentItem {
  id          String   @id @default(uuid())
  title       String
  description String?
  contentType String // document, image, video, audio, other
  fileUrl     String?
  fileSize    Int?
  mimeType    String?
  category    String?
  tags        String[]
  status      String   @default("draft") // draft, published, archived
  isPublic    Boolean  @default(false)
  uploadedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  uploader User @relation("ContentUploader", fields: [uploadedBy], references: [id])

  @@map("content_items")
}

model ContentCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  parent   ContentCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ContentCategory[] @relation("CategoryHierarchy")

  @@map("content_categories")
}

// Policy Alert System
model PolicyAlert {
  id        String    @id @default(uuid())
  title     String
  message   String
  alertType String // info, warning, critical
  regions   String[] // Array of region codes (CH, DE, FR, etc.)
  isActive  Boolean   @default(true)
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  creator User @relation("PolicyAlertCreator", fields: [createdBy], references: [id])

  @@map("policy_alerts")
}

// API Key Management
model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyHash     String    @unique
  permissions String[] // Array of permission strings
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  creator User @relation("ApiKeyCreator", fields: [createdBy], references: [id])

  @@map("api_keys")
}

// Webhook Management
model Webhook {
  id            String    @id @default(uuid())
  name          String
  url           String
  events        String[] // Array of event types
  secret        String? // Webhook secret for verification
  isActive      Boolean   @default(true)
  lastTriggered DateTime?
  failureCount  Int       @default(0)
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  creator User         @relation("WebhookCreator", fields: [createdBy], references: [id])
  logs    WebhookLog[]

  @@map("webhooks")
}

model WebhookLog {
  id           String   @id @default(uuid())
  webhookId    String
  event        String
  payload      Json
  response     Json?
  statusCode   Int?
  success      Boolean
  errorMessage String?
  triggeredAt  DateTime @default(now())

  // Relations
  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_logs")
}

// Foundation Lead Response System
// Tracks individual foundation responses to parent leads
model FoundationLeadResponse {
  id           String   @id @default(uuid())
  leadId       String
  foundationId String   // Organization ID of the foundation
  status       String   // INTERESTED, NOT_INTERESTED, NEEDS_MORE_INFO, ENROLLED
  message      String?  @db.Text
  respondedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  lead         ParentLead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  foundation   Organization @relation("FoundationLeadResponses", fields: [foundationId], references: [id])

  @@unique([leadId, foundationId])
  @@index([foundationId])
  @@index([status])
  @@map("foundation_lead_responses")
}

// Support Ticket System
model SupportTicket {
  id          String    @id @default(uuid())
  userId      String
  subject     String
  message     String    @db.Text
  category    String    @default("GENERAL") // GENERAL, TECHNICAL, BILLING, FEATURE_REQUEST
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user        User             @relation("UserSupportTickets", fields: [userId], references: [id])
  assignee    User?            @relation("AssignedSupportTickets", fields: [assignedTo], references: [id])
  responses   TicketResponse[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@map("support_tickets")
}

model TicketResponse {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  message   String   @db.Text
  isStaff   Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation("UserTicketResponses", fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_responses")
}

// Foundation Calendar Events
model CalendarEvent {
  id                String    @id @default(uuid())
  organizationId    String
  title             String
  description       String?   @db.Text
  eventType         String    // appointment, interview, service, meeting, reminder, custom
  startTime         DateTime
  endTime           DateTime?
  allDay            Boolean   @default(false)
  location          String?
  relatedEntityType String?   // service_request, job_application, parent_lead, etc.
  relatedEntityId   String?
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  organization Organization @relation("OrganizationCalendarEvents", fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User?        @relation("UserCalendarEvents", fields: [createdBy], references: [id])

  @@index([organizationId])
  @@index([startTime])
  @@index([eventType])
  @@map("calendar_events")
}

// Partner Organizations (External Partners/Sponsors)
enum PartnerType {
  ACADEMIC
  CORPORATE
  GOVERNMENTAL
  NON_PROFIT
  MEDIA
  TECHNOLOGY
}

model Partner {
  id            String      @id @default(uuid())
  name          String
  type          PartnerType
  description   String?     @db.Text
  websiteUrl    String?
  countryRegion String?
  contactEmail  String?
  contactPhone  String?
  contactPerson String?
  
  // Asset relations
  logoAssetId   String?
  
  // Status and visibility
  isActive      Boolean     @default(true)
  isFeatured    Boolean     @default(false)
  displayOrder  Int         @default(0)
  
  // Dates
  partnershipStart DateTime?
  partnershipEnd   DateTime?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([isFeatured])
  @@index([displayOrder])
  @@map("partners")
}

// Seed Record - Tracks completed database seeds to prevent re-running
model SeedRecord {
  id          String   @id @default(uuid())
  seedName    String   @unique @map("seed_name")
  version     String?  // Optional version for tracking seed versions
  executedAt  DateTime @default(now()) @map("executed_at")
  executedBy  String?  @map("executed_by") // system, cli, etc.
  metadata    Json?    // Additional data about the seed run
  
  @@map("seed_records")
}

// =====================================
// Mailing List Feature
// =====================================

enum MailingCampaignStatus {
  DRAFT
  SENDING
  SENT
  FAILED
  CANCELLED
}

model MailingSegment {
  id             String    @id @default(uuid())
  name           String
  description    String?   @db.Text
  filtersJson    Json      @map("filters_json")
  createdById    String    @map("created_by_id")
  estimatedSize  Int?      @map("estimated_size")
  lastComputedAt DateTime? @map("last_computed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  campaigns MailingCampaign[]

  @@index([createdById])
  @@map("mailing_segments")
}

model MailingCampaign {
  id             String                @id @default(uuid())
  subject        String
  bodyHtml       String                @db.Text @map("body_html")
  bodyText       String?               @db.Text @map("body_text")

  // Recipient source (one must be set)
  segmentId      String?               @map("segment_id")
  filtersJson    Json?                 @map("filters_json")

  // Status & progress
  status         MailingCampaignStatus @default(DRAFT)
  totalEstimated Int                   @default(0) @map("total_estimated")
  sentCount      Int                   @default(0) @map("sent_count")
  failedCount    Int                   @default(0) @map("failed_count")
  cursor         String?

  // Admin tracking
  createdById    String                @map("created_by_id")
  sentAt         DateTime?             @map("sent_at")
  completedAt    DateTime?             @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  segment MailingSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdById])
  @@index([segmentId])
  @@map("mailing_campaigns")
}

// Custom mailing lists — admin-curated static lists of users
model MailingCustomList {
  id          String @id @default(uuid())
  name        String
  description String? @db.Text
  createdById String @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members MailingCustomListMember[]

  @@index([createdById])
  @@map("mailing_custom_lists")
}

model MailingCustomListMember {
  id     String @id @default(uuid())
  listId String @map("list_id")
  userId String @map("user_id")

  addedAt DateTime @default(now()) @map("added_at")

  list MailingCustomList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listId, userId])
  @@index([listId])
  @@index([userId])
  @@map("mailing_custom_list_members")
}

model MailingTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  subject     String
  bodyHtml    String   @db.Text @map("body_html")
  bodyText    String?  @db.Text @map("body_text")
  createdById String   @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdById])
  @@map("mailing_templates")
}

// ─── Replacement Staffing (Phase 3) ───────────────────────────────────────────

enum UrgencyLevel {
  NORMAL
  URGENT
}

enum CompensationType {
  PAID
  UNPAID
  STIPEND
}

enum ReplacementRequestStatus {
  OPEN
  MATCHED
  FILLED
  CANCELLED
}

enum ReplacementMatchStatus {
  PROPOSED
  ACCEPTED
  DECLINED
  CONFIRMED
}

model ReplacementRequest {
  id             String                   @id @default(uuid())
  foundationId   String
  requestedById  String
  startDate      DateTime
  endDate        DateTime
  shiftStart     String?                  // e.g. "08:00"
  shiftEnd       String?                  // e.g. "17:00"
  role           String                   // e.g. "Educator", "Assistant"
  description    String?                  @db.Text
  location       String?
  urgency        UrgencyLevel             @default(NORMAL)
  status         ReplacementRequestStatus @default(OPEN)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  foundation     Organization             @relation("FoundationReplacementRequests", fields: [foundationId], references: [id])
  requestedBy    User                     @relation("UserReplacementRequests", fields: [requestedById], references: [id])
  matches        ReplacementMatch[]

  @@index([foundationId])
  @@index([status])
  @@map("replacement_requests")
}

model ReplacementMatch {
  id          String                 @id @default(uuid())
  requestId   String
  educatorId  String
  status      ReplacementMatchStatus @default(PROPOSED)
  proposedAt  DateTime               @default(now())
  respondedAt DateTime?
  note        String?

  request     ReplacementRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  educator    User                   @relation("EducatorReplacementMatches", fields: [educatorId], references: [id])

  @@unique([requestId, educatorId])
  @@index([requestId])
  @@index([educatorId])
  @@map("replacement_matches")
}

// ─── In-App Notifications (Phase 4) ───────────────────────────────────────────

enum NotificationType {
  REPLACEMENT_REQUEST_CREATED
  REPLACEMENT_MATCH_PROPOSED
  REPLACEMENT_MATCH_ACCEPTED
  REPLACEMENT_MATCH_DECLINED
  REPLACEMENT_MATCH_CONFIRMED
  JOB_APPLICATION_RECEIVED
  JOB_APPLICATION_STATUS_CHANGED
  LOW_REPLACEMENT_POOL
  INTERN_REQUEST_POSTED
  INTERN_APPLICATION_RECEIVED
  INTERN_APPLICATION_ACCEPTED
  INTERN_APPLICATION_DECLINED
  INTERN_APPLICATION_CONFIRMED
  GENERAL
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType @default(GENERAL)
  title       String
  body        String
  link        String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user        User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

// ─── Intern Pool (Hybrid: interns apply + foundations can propose) ─────────────

enum InternPoolRequestStatus {
  OPEN
  REVIEWING
  FILLED
  CANCELLED
}

enum InternPoolApplicationStatus {
  APPLIED
  REVIEWING
  ACCEPTED
  DECLINED
  CONFIRMED
}

model InternPoolRequest {
  id               String                  @id @default(uuid())
  foundationId     String
  postedById       String
  title            String
  startDate        DateTime
  endDate          DateTime
  role             String
  description      String?                 @db.Text
  location         String?
  supervisorName   String?
  compensationType CompensationType         @default(UNPAID)
  weeklyHours      Int?
  status           InternPoolRequestStatus @default(OPEN)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  foundation   Organization           @relation("FoundationInternPoolRequests", fields: [foundationId], references: [id])
  postedBy     User                   @relation("UserInternPoolRequests", fields: [postedById], references: [id])
  applications InternPoolApplication[]

  @@index([foundationId])
  @@index([status])
  @@map("intern_pool_requests")
}

model InternPoolApplication {
  id               String                     @id @default(uuid())
  requestId        String
  applicantId      String
  status           InternPoolApplicationStatus @default(APPLIED)
  motivationLetter String?                    @db.Text
  appliedAt        DateTime                   @default(now())
  respondedAt      DateTime?
  note             String?

  request   InternPoolRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  applicant User              @relation("InternPoolApplications", fields: [applicantId], references: [id])

  @@unique([requestId, applicantId])
  @@index([requestId])
  @@index([applicantId])
  @@map("intern_pool_applications")
}
