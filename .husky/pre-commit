# Run lint-staged on staged files (optional - non-blocking)
if command -v lint-staged >/dev/null 2>&1; then
  lint-staged || echo "⚠️  lint-staged had issues, but continuing with other checks..."
else
  echo "lint-staged not configured at repo root; skipping"
fi

# Validate translation files (mandatory - fails commit on error)
node scripts/validate-translations.mjs || exit 1

# Extract i18n keys from codebase (mandatory - fails commit on error)
pnpm run extract:i18n-keys || exit 1

# Check for missing i18n keys (mandatory - fails commit on error)
pnpm run check:i18n-keys || exit 1

# Find hardcoded strings that should be translated (mandatory - fails commit on error)
node scripts/find-hardcoded-strings.mjs || exit 1

# Lint translation values for quality issues (mandatory - fails commit on error)
node scripts/lint-translation-values.mjs || exit 1

# Check for Prisma schema drift (warns if schema changes lack migrations)
# Only run if schema.prisma is being committed
if git diff --cached --name-only | grep -q "api/prisma/schema.prisma"; then
  echo "📋 Checking for Prisma schema drift..."
  if [ -f "api/scripts/check-schema-drift.mjs" ]; then
    # Check if there's also a migration being committed
    if git diff --cached --name-only | grep -q "api/prisma/migrations/"; then
      echo "✅ Schema changes include migration files"
    else
      echo ""
      echo "⚠️  WARNING: schema.prisma is being committed without new migrations!"
      echo ""
      echo "   If you've added/modified fields, you should run:"
      echo "   cd api && npx prisma migrate dev --name <migration_name>"
      echo ""
      echo "   Then stage the generated migration file."
      echo ""
      # Don't block commit, just warn (CI will catch it)
    fi
  fi
fi
