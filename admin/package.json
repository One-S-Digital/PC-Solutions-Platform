{
  "name": "admin",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "cd ../packages/ui && pnpm run build && cd ../../admin && vite build",
    "build:with-deps": "cd ../packages/ui && pnpm run build && cd ../../admin && vite build",
    "dev": "vite",
    "start": "serve -s dist -l 3000",
    "extract-i18n": "i18next-parser",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch",
    "preview": "vite preview",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clerk/clerk-js": "^5.102.1",
    "@clerk/clerk-react": "^5.53.3",
    "@headlessui/react": "^2.0.0",
    "@heroicons/react": "^2.1.0",
    "@repo/ui": "workspace:*",
    "@tanstack/react-query": "^5.89.0",
    "@workspace/types": "workspace:*",
    "clsx": "^2.1.0",
    "dompurify": "^3.3.1",
    "emoji-picker-react": "^4.15.2",
    "i18next": "^25.5.2",
    "i18next-parser": "^8.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.12.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-legacy": "^6.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.4.0",
    "serve": "^14.2.1",
    "terser": "^5.36.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^2.0.0"
  }
}
